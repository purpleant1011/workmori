# Workmori(가칭) 환경변수 예시
# 본 파일을 .env로 복사한 뒤 실제 값을 채워 넣으세요. .env는 git에 커밋하지 마세요.

# Rails / DB
RAILS_ENV=development
RAILS_MAX_THREADS=5
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=hochari

# Active Storage
ACTIVE_STORAGE_SERVICE=local

# 운영자/플랫폼 시크릿 — 운영자 부팅에 사용
WORKMORI_BOOTSTRAP_TOKEN=change-me-bootstrap
# 솔트 (Rails credentials, Active Record Encryption 키)
# bin/rails db:encryption:init 으로 생성해 credentials에 저장

# AI 공급자 — 비어있으면 stub 모드 (자리표시자 텍스트)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
MINIMAX_API_KEY=
AI_PROVIDER=stub

# Discord (첫 실제 채널)
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_DEFAULT_CHANNEL_ID=

# Meta Graph API (Instagram Business) — 비용 0, Business 계정 + Facebook Page 필요
# 토큰 발급: developers.facebook.com → 앱 생성 → Instagram Graph API
# 장기 토큰: 60일마다 refresh 필요 (refresh_token 사용)
META_GRAPH_API_TOKEN=
META_GRAPH_API_VERSION=v19.0

# Threads API — 비용 0, OAuth 2.0
# 토큰 발급: developers.facebook.com → 앱 → Threads API
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=
THREADS_API_VERSION=v1.0

# Hermes / 워커
HERMES_PROVIDER=fake   # fake | real
WORKER_API_TOKEN=change-me-long-random-string

# Real Hermes Adapter — set both to route Automation::Provider.active through Hermes Agent
HERMES_AGENT_URL=
HERMES_AGENT_TOKEN=
HERMES_AGENT_TIMEOUT=25
HERMES_MAX_RETRIES=2

# 공개 사이트
BRAND_NAME=워크모리
BRAND_NAME_EN=Workmori
BRAND_TAGLINE=사장님의 일을 기억하고 스스로 이어가는 AI 직원
BRAND_PROVISIONAL=true
CONTACT_EMAIL=hello@workmori.example
CONTACT_PHONE=


# Discord-Native 확장 (2026-07-12 시작, P0 문서 완료)
# Discord App: https://discord.com/developers/applications
# Bot Token은 발급 즉시 안전한 곳(macOS Keychain 권장)에 저장
# 실제 값은 절대 git에 커밋하지 마세요

# Discord Bot — 사람 단계 (운영자가 발급)
# DISCORD_BOT_TOKEN=                    # Bot 탭 → Token
# DISCORD_APPLICATION_ID=                # General Information
# DISCORD_PUBLIC_KEY=                   # interactions endpoint 검증용

# Discord Gateway → Rails 내부 API 인증 (우리 측 생성)
# openssl rand -hex 32 로 64자 생성
# DISCORD_GATEWAY_SERVICE_TOKEN=
# DISCORD_GATEWAY_ALLOWED_IPS=           # 콤마 구분, 비워두면 모든 IP 허용 (개발용)

# Hermes MCP — Hermes Agent → Rails API 인증 (우리 측 생성)
# HERMES_MCP_TOKEN=
# HERMES_MCP_RATE_LIMIT_PER_MIN=30
# HERMES_MCP_PARALLEL_TOOL_CALLS=false

# Gemini Provider (사람 단계)
# Gemini Google Cloud Project: console.cloud.google.com
# Auth Key 또는 Service Account 생성 후 안전한 곳에 저장
# GEMINI_API_KEY=
# GOOGLE_CLOUD_PROJECT_ID=
# SOHEE_GEMINI_DEFAULT_PROVIDER=gemini_api
# SOHEE_GEMINI_DEFAULT_MODEL=gemini-3.5-flash
# SOHEE_GEMINI_FALLBACK_MODEL=
# SOHEE_GEMINI_DEFAULT_THINKING=low
# GEMINI_REQUEST_TIMEOUT=30

# Antigravity CLI Dev Provider — 개발 전용, 프로덕션에서 절대 로딩 금지
# ANTIGRAVITY_CLI_PATH=
# ANTIGRAVITY_AGENT_URL=
# ANTIGRAVITY_WORKSPACE=
# FeatureFlag: antigravity_cli_enabled (기본 false)

# Workers 엔드포인트 (P1, 2026-07-12)
# 워커가 결과를 보낼 때 접근하는 Rails 기본 URL
RAILS_INTERNAL_API_BASE=http://localhost:3000

# Sentry/오류 추적 (선택 — 무료 tier: 5K events/month)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
