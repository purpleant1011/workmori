<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <title><%= brand.brand_name %> 어드민</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <%= csrf_meta_tags %>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 text-slate-900">
  <header class="bg-white shadow">
    <div class="max-w-7xl mx-auto px-4 py-3 flex justify-between items-center">
      <a href="<%= app_root_path %>" class="font-bold text-lg"><%= brand.brand_name %></a>
      <nav class="text-sm flex gap-4">
        <a href="<%= app_root_path %>" class="hover:text-emerald-700">대시보드</a>
        <a href="<%= app_ai_employees_path %>" class="hover:text-emerald-700">AI 직원</a>
        <a href="<%= app_pending_for_review_path %>" class="hover:text-emerald-700">검수</a>
        <a href="<%= app_automation_dashboard_path %>" class="hover:text-emerald-700">자동화</a>
        <a href="<%= app_knowledge_sources_path %>" class="hover:text-emerald-700">지식</a>
        <a href="<%= app_reports_path %>" class="hover:text-emerald-700">보고</a>
        <a href="<%= app_settings_path %>" class="hover:text-slate-600">설정</a>
        <a href="<%= app_new_termination_path %>" class="hover:text-rose-700">해지</a>
        <%= button_to "로그아웃", logout_path, method: :delete, class: "text-slate-500 hover:text-rose-700" %>
      </nav>
    </div>
  </header>

  <main class="max-w-7xl mx-auto p-4">
    <% if notice %><div class="rounded bg-emerald-50 border border-emerald-200 px-4 py-2 mb-4 text-emerald-800"><%= notice %></div><% end %>
    <% if alert  %><div class="rounded bg-rose-50 border border-rose-200 px-4 py-2 mb-4 text-rose-800"><%= alert  %></div><% end %>
    <%= yield %>
  </main>
</body>
</html>
