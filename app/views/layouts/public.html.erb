<!DOCTYPE html>
<html lang="ko">
  <head>
    <title><%= [brand.brand_name, content_for(:title)].compact.join(" · ") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= brand.brand_tagline %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "inter-font", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <style>
      :root { --brand-provisional: "<%= brand.brand_provisional ? 'true' : 'false' %>"; }
      .provisional-banner { display: var(--brand-provisional) === 'true' ? block : none; }
    </style>
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-800">
    <header class="bg-white shadow">
      <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
        <%= link_to public_root_path, class: "flex items-center gap-2" do %>
          <span class="font-bold text-xl text-slate-900"><%= brand.brand_name %></span>
        <% end %>
        <nav class="flex gap-5 text-sm text-slate-700">
          <%= link_to "AI 직원",      public_product_ai_employee_path %>
          <%= link_to "고객 사례",    public_case_studies_path %>
          <%= link_to "문의",         public_contact_path %>
          <% if signed_in? %>
            <%= link_to "관리자",      app_root_path, class: "font-semibold text-emerald-700" %>
            <%= link_to "로그아웃",    logout_path, method: :delete, data: { turbo_method: :delete } %>
          <% elsif signed_in_as_platform? %>
            <%= link_to "플랫폼",      platform_root_path, class: "font-semibold text-purple-700" %>
            <%= link_to "로그아웃",    platform_logout_path, method: :delete, data: { turbo_method: :delete } %>
          <% else %>
            <%= link_to "로그인",      new_user_session_path %>
          <% end %>
        </nav>
      </div>
    </header>

    <main class="max-w-6xl mx-auto px-4 py-8">
      <% if notice.present? %>
        <div class="mb-4 p-3 rounded bg-emerald-100 text-emerald-900"><%= notice %></div>
      <% end %>
      <% if alert.present? %>
        <div class="mb-4 p-3 rounded bg-rose-100 text-rose-900"><%= alert %></div>
      <% end %>
      <%= yield %>
    </main>

    <footer class="mt-12 border-t border-slate-200 bg-white">
      <div class="max-w-6xl mx-auto px-4 py-6 text-sm text-slate-500 flex flex-wrap gap-4 justify-between">
        <div>© <%= Date.today.year %> <%= brand.brand_name %>.</div>
        <nav class="flex gap-4">
          <%= link_to "이용약관", public_page_path(slug: "terms") %>
          <%= link_to "개인정보처리방침", public_page_path(slug: "privacy") %>
        </nav>
      </div>
    </footer>
  </body>
</html>
