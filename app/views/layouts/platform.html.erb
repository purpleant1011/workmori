<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <title><%= brand.brand_name %> · 운영자 콘솔</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <%= csrf_meta_tags %>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50 text-slate-900">
  <header class="bg-white border-b border-slate-200">
    <div class="max-w-7xl mx-auto px-4 py-3 flex items-center gap-4">
      <a href="<%= platform_root_path %>" class="flex items-center gap-2">
        <span class="text-2xl">🌸</span>
        <div>
          <div class="font-semibold text-slate-900"><%= brand.brand_name %></div>
          <div class="text-[11px] text-slate-500 -mt-0.5">운영형 AI 마케팅 직원</div>
        </div>
      </a>

      <div class="ml-auto flex items-center gap-3 text-sm">
        <% if @current_account&.name %>
          <span class="text-slate-600 hidden sm:inline"><%= @current_account.name %></span>
          <% if @setup_readiness %>
            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium <%= @setup_readiness[:ready] ? 'bg-emerald-100 text-emerald-800' : 'bg-amber-100 text-amber-800' %>">
              <span><%= @setup_readiness[:ready] ? '✅' : '🛠️' %></span>
              <span>셋업 준비도 <%= @setup_readiness[:percent] %>%</span>
            </span>
          <% end %>
        <% end %>
        <%= button_to "로그아웃", platform_logout_path, method: :delete, form: { class: "inline" }, class: "text-slate-500 hover:text-rose-600 text-sm" %>
      </div>
    </div>
  </header>

  <div class="max-w-[1440px] mx-auto px-4 py-4 flex gap-4">
    <%# ── 사이드바 — 7-IA 운영자 콘솔 (2026-07-15 리뉴얼) ── %>
    <aside class="w-56 flex-shrink-0">
      <% account = @current_account || @account %>
      <% if account %>
        <%= render partial: "platform/accounts/consoles/operator_sidebar", locals: { account: account, current_controller: controller_name, current_action: action_name } %>
      <% else %>
        <nav class="bg-white rounded-lg border border-slate-200 overflow-hidden text-sm">
          <a href="<%= platform_accounts_path %>" class="block px-4 py-2.5 hover:bg-slate-50">🌸 사업자 목록</a>
        </nav>
      <% end %>
    </aside>

    <main class="flex-1 min-w-0">
      <% if notice %><div class="rounded-md bg-emerald-50 border border-emerald-200 px-4 py-2 mb-4 text-emerald-800 text-sm"><%= notice %></div><% end %>
      <% if alert  %><div class="rounded-md bg-rose-50 border border-rose-200 px-4 py-2 mb-4 text-rose-800 text-sm"><%= alert %></div><% end %>
      <%= yield %>
    </main>
  </div>
</body>
</html>