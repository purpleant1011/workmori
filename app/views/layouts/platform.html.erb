<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="utf-8">
  <title><%= brand.brand_name %> 운영자</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <%= csrf_meta_tags %>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-900 text-slate-100 min-h-screen">
  <header class="bg-slate-800 border-b border-slate-700">
    <div class="max-w-7xl mx-auto px-4 py-3 flex justify-between items-center">
      <a href="<%= platform_root_path %>" class="font-bold text-emerald-400"><%= brand.brand_name %> · 운영자 콘솔</a>
      <nav class="text-sm flex gap-4">
        <a href="<%= platform_root_path %>" class="hover:text-emerald-300">대시보드</a>
        <a href="<%= platform_accounts_path %>" class="hover:text-emerald-300">계정</a>
        <a href="<%= platform_inquiries_path %>" class="hover:text-emerald-300">문의</a>
        <a href="<%= platform_industries_path %>" class="hover:text-emerald-300">산업</a>
        <a href="<%= platform_feature_flags_path %>" class="hover:text-emerald-300">기능</a>
        <a href="<%= platform_reports_path %>" class="hover:text-emerald-300">보고</a>
        <a href="<%= platform_hermes_path %>" class="hover:text-emerald-300">Hermes</a>
        <a href="<%= platform_announcements_path %>" class="hover:text-emerald-300">공지</a>
        <%= button_to "로그아웃", platform_logout_path, method: :delete, class: "text-slate-400 hover:text-rose-300" %>
      </nav>
    </div>
  </header>

  <main class="max-w-7xl mx-auto p-4">
    <% if notice %><div class="rounded bg-emerald-700/30 border border-emerald-500 px-4 py-2 mb-4 text-emerald-200"><%= notice %></div><% end %>
    <%= yield %>
  </main>
</body>
</html>
