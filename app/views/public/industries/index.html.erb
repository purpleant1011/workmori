<% content_for :title, "업종별 워크모리" %>
<section class="py-12">
  <h1 class="text-4xl font-bold text-slate-900">업종별 워크모리</h1>
  <p class="mt-4 text-lg text-slate-700 max-w-3xl">
    업종마다 다른 영업 패턴·고객 질문·금지 사항에 맞춰 AI 직원이 다르게 설정됩니다.
  </p>
</section>

<section class="py-8">
  <% if @industries.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @industries.each do |industry| %>
        <div class="p-6 rounded-lg bg-white shadow-sm border border-slate-200">
          <h2 class="text-xl font-semibold text-slate-900">
            <%= industry.starter_ai_employee&.dig("display_name") || industry.industry_code.humanize %>
          </h2>
          <div class="mt-2 text-xs text-slate-500">업종 코드: <%= industry.industry_code %></div>
          <% if industry.starter_ai_employee["tone"].present? %>
            <div class="mt-3 text-sm text-slate-700">톤: <%= industry.starter_ai_employee["tone"] %></div>
          <% end %>
          <% if industry.starter_guardrails.is_a?(Array) && industry.starter_guardrails.any? %>
            <div class="mt-3 text-xs text-slate-500">
              <div class="font-semibold">가드레일</div>
              <div class="mt-1">
                <%= industry.starter_guardrails.first(2).map { |g| g["patterns"] }.flatten.first(3).join(", ") %>
              </div>
            </div>
          <% end %>
          <div class="mt-4">
            <%= link_to "상세 →", industry_path(industry.industry_code), class: "text-emerald-700 font-semibold" %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="p-6 rounded-lg bg-amber-50 border border-amber-200">
      <p class="text-amber-800">아직 등록된 업종 템플릿이 없습니다.</p>
    </div>
  <% end %>
</section>