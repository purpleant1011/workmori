<% content_for(:title, "로그인 — WorkMori") %>

<section class="mx-auto max-w-md px-6 py-16">
  <header class="mb-8 text-center">
    <h1 class="text-3xl font-bold text-slate-900">WorkMori 로그인</h1>
    <p class="mt-2 text-sm text-slate-600">사업장 슬러그 또는 가입한 이메일로 로그인하세요.</p>
  </header>

  <% if flash[:alert] %>
    <div class="mb-4 rounded-md bg-rose-50 border border-rose-200 px-4 py-3 text-sm text-rose-800">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <%= form_with url: user_sessions_path, method: :post, local: true, class: "space-y-5" do |f| %>
    <div>
      <label for="account_or_email" class="block text-sm font-medium text-slate-700">사업장 슬러그 또는 이메일</label>
      <%= f.text_field :account_or_email,
            value: @account_or_email,
            class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-indigo-500",
            placeholder: "demo-skincare 또는 owner@example.com",
            autocomplete: "username",
            required: true %>
    </div>

    <div>
      <label for="password" class="block text-sm font-medium text-slate-700">비밀번호</label>
      <%= f.password_field :password,
            class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-indigo-500",
            autocomplete: "current-password",
            required: true %>
    </div>

    <div class="flex items-center justify-between text-sm">
      <a href="<%= new_user_magic_link_path %>" class="text-indigo-600 hover:underline">매직 링크로 로그인</a>
      <a href="<%= new_signup_path %>" class="text-slate-500 hover:underline">회원가입</a>
    </div>

    <%= f.submit "로그인",
          class: "w-full rounded-md bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 cursor-pointer" %>
  <% end %>

  <div class="mt-10 rounded-md bg-slate-50 border border-slate-200 px-4 py-3 text-xs text-slate-600">
    <p class="font-semibold text-slate-700 mb-1">데모 계정 안내</p>
    <p>데모용 dev 로그인은 <code class="rounded bg-slate-200 px-1 py-0.5">POST /dev_login/business</code>에 이메일 <code class="rounded bg-slate-200 px-1 py-0.5">owner@demo.example</code> 로 호출하세요.</p>
  </div>
</section>