<%# ── 명세 §4 공통 컴포넌트: EmptyState ── %>
<%
  icon    = local_assigns[:icon] || "✨"
  title   = local_assigns[:title] || "아직 표시할 항목이 없습니다."
  body    = local_assigns[:body]
  cta     = local_assigns[:cta]
%>
<div class="rounded-lg border border-slate-200 bg-white p-12 text-center">
  <p class="text-3xl mb-3"><%= icon %></p>
  <p class="text-sm font-medium text-slate-700"><%= title %></p>
  <% if body.present? %>
    <p class="text-xs text-slate-500 mt-2"><%= body %></p>
  <% end %>
  <% if cta.present? %>
    <div class="mt-4"><%= cta %></div>
  <% end %>
</div>