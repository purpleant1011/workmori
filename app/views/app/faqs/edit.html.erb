<% content_for(:title, "FAQ 수정 — Sohee Project") %>

<header class="mb-6">
  <h1 class="text-2xl font-bold text-slate-900">FAQ 수정</h1>
</header>

<%= form_with model: @faq, url: app_faq_path(@faq), method: :patch, scope: :faq, local: true, class: "space-y-5" do |f| %>
  <div>
    <label class="block text-sm font-medium text-slate-700">질문</label>
    <%= f.text_field :question, required: true, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
  </div>
  <div>
    <label class="block text-sm font-medium text-slate-700">답변</label>
    <%= f.text_area :answer, rows: 5, required: true, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
  </div>
  <div>
    <label class="block text-sm font-medium text-slate-700">태그 (쉼표 구분)</label>
    <%= f.text_field :tags_json, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
  </div>
  <div class="grid grid-cols-2 gap-5">
    <div>
      <label class="block text-sm font-medium text-slate-700">민감도</label>
      <%= f.select :risk_level, [["낮음 (low)", "low"], ["보통 (medium)", "medium"], ["높음 (high)", "high"]], {}, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div class="flex items-end">
      <label class="inline-flex items-center gap-2 text-sm text-slate-700">
        <%= f.check_box :active, class: "rounded border-slate-300" %>
        활성
      </label>
    </div>
  </div>
  <div class="flex items-center justify-between pt-4 border-t">
    <%= link_to "← 목록으로", app_faqs_path, class: "text-sm text-slate-500 hover:underline" %>
    <div class="flex items-center gap-3">
      <%= button_to "삭제", app_faq_path(@faq), method: :delete, data: { turbo_confirm: "정말 삭제할까요?" }, class: "rounded-md bg-rose-100 px-4 py-2 text-sm font-semibold text-rose-700 hover:bg-rose-200 cursor-pointer" %>
      <%= f.submit "FAQ 수정", class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 cursor-pointer" %>
    </div>
  </div>
<% end %>