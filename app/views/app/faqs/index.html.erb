<% content_for(:title, "FAQ — WorkMori") %>

<header class="mb-6 flex items-center justify-between">
  <div>
    <h1 class="text-2xl font-bold text-slate-900">FAQ</h1>
    <p class="mt-1 text-sm text-slate-500">AI 직원이 표준 답변으로 활용하는 지식 베이스입니다.</p>
  </div>
  <%= link_to "+ FAQ 등록", app_new_faq_path, class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" %>
</header>

<% if @faqs.empty? %>
  <div class="rounded-md border border-dashed border-slate-300 bg-slate-50 px-6 py-12 text-center">
    <p class="text-sm text-slate-500">아직 FAQ가 없습니다. 자주 받는 질문과 표준 답변을 등록해 보세요.</p>
    <%= link_to "FAQ 등록하러 가기", app_new_faq_path, class: "mt-4 inline-block rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" %>
  </div>
<% else %>
  <ul class="space-y-3">
    <% @faqs.each do |faq| %>
      <li class="rounded-md border border-slate-200 bg-white px-5 py-4 hover:shadow-sm transition">
        <div class="flex items-start justify-between gap-4">
          <div class="flex-1">
            <p class="font-semibold text-slate-900">Q. <%= faq.question %></p>
            <p class="mt-1 text-sm text-slate-600 line-clamp-2">A. <%= faq.answer %></p>
            <div class="mt-2 flex flex-wrap gap-2 text-xs text-slate-500">
              <% if faq.active %><span class="rounded-full bg-emerald-100 px-2 py-0.5 text-emerald-700">활성</span><% else %><span class="rounded-full bg-slate-100 px-2 py-0.5 text-slate-500">비활성</span><% end %>
              <% if faq.risk_level.present? %><span class="rounded-full bg-amber-100 px-2 py-0.5 text-amber-700">민감도: <%= faq.risk_level %></span><% end %>
            </div>
          </div>
          <div class="flex flex-col gap-1 text-xs">
            <%= link_to "수정", app_edit_faq_path(faq), class: "text-indigo-600 hover:underline" %>
          </div>
        </div>
      </li>
    <% end %>
  </ul>
<% end %>