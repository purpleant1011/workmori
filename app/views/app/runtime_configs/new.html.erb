<% content_for :title, "새 런타임 번들 · #{@current_account.name}" %>

<div class="mb-4">
  <h1 class="text-2xl font-bold">+ 새 런타임 번들 생성</h1>
  <p class="text-xs text-slate-500 mt-0.5">
    현재 사업장·페르소나·채널·FAQ·자동화 상태를 스냅샷으로 직렬화합니다. (초안 상태로 생성되며, 별도 활성화 전까지 소희는 기존 활성 번들로 동작합니다.)
  </p>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
  <div>
    <div class="rounded-lg border border-slate-200 bg-white p-5">
      <h2 class="font-bold mb-3">📝 생성 정보</h2>
      <%= form_with url: app_runtime_configs_path, method: :post, local: true do |f| %>
        <div class="mb-3">
          <label class="block text-sm font-medium text-slate-700 mb-1">다음 버전 번호</label>
          <div class="px-3 py-2 bg-slate-100 rounded font-mono"><%= @next_version %></div>
        </div>
        <div class="mb-3">
          <label class="block text-sm font-medium text-slate-700 mb-1">변경 메모 (선택)</label>
          <%= f.text_area :change_summary, name: "change_summary", rows: 3, placeholder: "예: 신규 FAQ 3건 추가, 채널 매핑 정리", class: "w-full border border-slate-300 rounded p-2 text-sm" %>
        </div>
        <div class="flex gap-2">
          <%= f.submit "초안 생성", class: "px-4 py-2 bg-indigo-600 text-white rounded text-sm font-medium hover:bg-indigo-700 cursor-pointer" %>
          <%= link_to "취소", app_runtime_configs_path, class: "px-4 py-2 bg-slate-100 hover:bg-slate-200 rounded text-sm" %>
        </div>
      <% end %>
    </div>
  </div>
  <div>
    <div class="rounded-lg border border-slate-200 bg-slate-50 p-5">
      <h2 class="font-bold mb-3">🔍 스냅샷 미리보기</h2>
      <p class="text-xs text-slate-500 mb-2">지금 저장되는 주요 키 (schema_version: sohee.runtime/v1)</p>
      <div class="bg-slate-900 text-slate-100 rounded p-3 overflow-x-auto max-h-96">
<pre class="text-xs font-mono whitespace-pre"><%= JSON.pretty_generate(@snapshot.transform_values { |v| v.is_a?(Hash) || v.is_a?(Array) ? "(#{v.size} keys)" : v.to_s[0, 60] }) %></pre>
      </div>
    </div>
  </div>
</div>