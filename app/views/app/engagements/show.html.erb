<% content_for(:title, "Engagement 자동응대") %>
<header class="mb-6">
  <h1 class="text-2xl font-bold text-slate-900">Engagement 자동응대</h1>
  <p class="mt-1 text-sm text-slate-500">Instagram/Threads 댓글 자동 응답 + 인사이트 수집</p>
</header>

<div class="rounded-md border border-slate-200 bg-white p-6 mb-6">
  <h2 class="text-lg font-semibold text-slate-900"><%= @channel.kind.humanize %> · <%= @channel.handle %></h2>
  <p class="mt-1 text-sm text-slate-500">상태: <%= @channel.status %> · 마지막 연결 확인: <%= @channel.last_verified_at || "확인 안 됨" %></p>

  <div class="mt-4">
    <%= button_to "지금 자동 응대 실행", app_engagement_path(@channel), method: :post, class: "inline-flex items-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700" %>
  </div>
</div>

<% if @result %>
  <div class="rounded-md border border-slate-200 bg-white p-6 mb-6">
    <h3 class="font-semibold text-slate-900">실행 결과</h3>
    <pre class="mt-3 overflow-x-auto rounded bg-slate-50 p-3 text-xs"><%= JSON.pretty_generate(@result.as_json) rescue @result.inspect %></pre>
  </div>
<% end %>

<div class="rounded-md border border-slate-200 bg-white p-6">
  <h3 class="font-semibold text-slate-900">최근 자동 응대 이벤트 (최근 20건)</h3>
  <% if @recent_events.any? %>
    <ul class="mt-3 divide-y divide-slate-200 text-sm">
      <% @recent_events.each do |ev| %>
        <li class="py-2">
          <div class="text-xs text-slate-500"><%= ev.created_at.strftime("%Y-%m-%d %H:%M:%S") %> · <%= ev.metadata["reply_text"]&.truncate(80) %></div>
          <div class="font-mono text-xs text-slate-700">media=<%= ev.metadata["media_id"] %> · reply_id=<%= ev.metadata["reply_id"] %></div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="mt-3 text-sm text-slate-500">아직 자동 응대 이력이 없습니다. 위 버튼을 눌러 실행하거나 <code>EngagementTickJob</code> (6시간마다 자동)을 기다려주세요.</p>
  <% end %>
</div>