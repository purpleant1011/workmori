<% content_for(:title, "상품 — Sohee Project") %>

<header class="mb-6 flex items-center justify-between">
  <div>
    <h1 class="text-2xl font-bold text-slate-900">상품 / 서비스</h1>
    <p class="mt-1 text-sm text-slate-500">AI 직원이 추천·소개할 수 있도록 상품과 서비스를 등록합니다.</p>
  </div>
  <%= link_to "+ 상품 등록", app_new_product_path, class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" %>
</header>

<% if @products.empty? %>
  <div class="rounded-md border border-dashed border-slate-300 bg-slate-50 px-6 py-12 text-center">
    <p class="text-sm text-slate-500">아직 등록된 상품이 없습니다.</p>
    <%= link_to "상품 등록하러 가기", app_new_product_path, class: "mt-4 inline-block rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" %>
  </div>
<% else %>
  <div class="overflow-hidden rounded-md border border-slate-200 bg-white">
    <table class="w-full text-sm">
      <thead class="bg-slate-50 text-left text-xs uppercase tracking-wider text-slate-500">
        <tr>
          <th class="px-4 py-3">상품명</th>
          <th class="px-4 py-3">기본 가격</th>
          <th class="px-4 py-3">소요시간</th>
          <th class="px-4 py-3">상태</th>
          <th class="px-4 py-3 text-right">관리</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @products.each do |product| %>
          <tr class="hover:bg-slate-50">
            <td class="px-4 py-3">
              <p class="font-medium text-slate-900"><%= product.name %></p>
              <p class="text-xs text-slate-500 line-clamp-1"><%= product.description %></p>
            </td>
            <td class="px-4 py-3 text-slate-700"><%= number_with_delimiter(product.base_price_krw) %>원</td>
            <td class="px-4 py-3 text-slate-700"><%= product.duration_min.to_i.positive? ? "#{product.duration_min}분" : "-" %></td>
            <td class="px-4 py-3">
              <% if product.active %><span class="rounded-full bg-emerald-100 px-2 py-0.5 text-xs text-emerald-700">활성</span><% else %><span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs text-slate-500">비활성</span><% end %>
            </td>
            <td class="px-4 py-3 text-right">
              <%= link_to "수정", app_edit_product_path(product), class: "text-xs text-indigo-600 hover:underline" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>