<% content_for(:title, "상품 수정 — Sohee Project") %>

<header class="mb-6">
  <h1 class="text-2xl font-bold text-slate-900">상품 수정</h1>
</header>

<%= form_with model: @product, url: app_product_path(@product), method: :patch, scope: :product, local: true, class: "space-y-5" do |f| %>
  <div>
    <label class="block text-sm font-medium text-slate-700">상품명</label>
    <%= f.text_field :name, required: true, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
  </div>
  <div>
    <label class="block text-sm font-medium text-slate-700">설명</label>
    <%= f.text_area :description, rows: 4, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
  </div>
  <div class="grid grid-cols-2 gap-5">
    <div>
      <label class="block text-sm font-medium text-slate-700">기본 가격 (KRW)</label>
      <%= f.number_field :base_price_krw, min: 0, step: 1000, required: true, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-700">소요 시간 (분)</label>
      <%= f.number_field :duration_min, min: 0, step: 5, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
  </div>
  <div class="flex items-center gap-2 pt-2">
    <%= f.check_box :active, class: "rounded border-slate-300" %>
    <label class="text-sm text-slate-700">활성</label>
  </div>
  <div class="flex items-center justify-between pt-4 border-t">
    <%= link_to "← 목록으로", app_products_path, class: "text-sm text-slate-500 hover:underline" %>
    <div class="flex items-center gap-3">
      <%= button_to "삭제", app_product_path(@product), method: :delete, data: { turbo_confirm: "정말 삭제할까요?" }, class: "rounded-md bg-rose-100 px-4 py-2 text-sm font-semibold text-rose-700 hover:bg-rose-200 cursor-pointer" %>
      <%= f.submit "상품 수정", class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 cursor-pointer" %>
    </div>
  </div>
<% end %>