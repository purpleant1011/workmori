<% content_for :title do %>자동화 규칙 - 신규<% end %>
<div class="px-6 py-8 max-w-3xl mx-auto">
  <h1 class="text-2xl font-semibold mb-6">+ 새 자동화 규칙</h1>
  <%= form_with model: @rule, url: app_automation_rules_path, local: true, class: "space-y-4 bg-white shadow rounded-lg p-6" do |f| %>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">규칙 이름</label>
      <%= f.text_field :name, required: true, class: "w-full px-3 py-2 border rounded" %>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">자연어 설명 (예: 매일 오전 9시에 신메뉴 사진 + 짧은 카피 작성)</label>
      <%= f.text_area :natural_language, rows: 3, class: "w-full px-3 py-2 border rounded" %>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">담당 AI 직원</label>
      <%= f.collection_select :ai_employee_id, @ai_employees, :id, :name, { prompt: "선택" }, { class: "w-full px-3 py-2 border rounded", required: true } %>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">주기</label>
      <select name="cadence" class="w-full px-3 py-2 border rounded">
        <option value="hourly">매시</option>
        <option value="daily" selected>매일</option>
        <option value="weekly">매주</option>
        <option value="monthly">매월</option>
        <option value="cron">cron</option>
        <option value="one_off">일회성</option>
      </select>
    </div>
    <div class="flex gap-2 pt-4">
      <%= f.submit "생성", class: "px-4 py-2 bg-indigo-600 text-white rounded hover:bg-indigo-700" %>
      <%= link_to "취소", app_automation_rules_path, class: "px-4 py-2 bg-gray-100 text-gray-700 rounded" %>
    </div>
  <% end %>
</div>
