<% content_for(:title, "확인할 일 · 소희 프로젝트") %>

<%# ── 헤더 (§7: 3 탭 통합, 명세 §7 권장) ── %>
<div class="mb-6">
  <h1 class="text-2xl font-bold text-slate-900">확인할 일</h1>
  <p class="text-xs text-slate-500 mt-1">소희가 한 일 중에서 원장님의 확인이 필요한 항목만 모았습니다.</p>
</div>

<%# ── 3 탭 네비게이션 ── %>
<div class="mb-6 border-b border-slate-200">
  <nav class="flex gap-1">
    <% [
      [App::ConfirmationsController::TAB_OPEN, "지금 확인", @counts[:open]],
      [App::ConfirmationsController::TAB_TEAM, "운영팀 확인 중", @counts[:team]],
      [App::ConfirmationsController::TAB_DONE, "처리 완료", @counts[:done]]
    ].each do |key, label, count| %>
      <%= link_to app_confirmations_path(tab: key),
            class: "px-4 py-2.5 text-sm font-medium border-b-2 -mb-px #{@tab == key ? 'border-emerald-500 text-emerald-700' : 'border-transparent text-slate-500 hover:text-slate-700 hover:border-slate-300'}" do %>
        <%= label %>
        <% if count.to_i > 0 %>
          <span class="ml-1.5 inline-flex items-center justify-center px-2 py-0.5 rounded-full <%= @tab == key ? 'bg-emerald-100 text-emerald-700' : 'bg-slate-100 text-slate-600' %> text-xs"><%= count %></span>
        <% end %>
      <% end %>
    <% end %>
  </nav>
</div>

<%# ── ① 원장님 답변 필요 (handoffs) ── %>
<section class="mb-6 rounded-lg border border-slate-200 bg-white">
  <header class="flex items-center justify-between px-5 py-3 border-b border-slate-100">
    <h2 class="font-bold text-slate-900">
      <% case @tab
         when App::ConfirmationsController::TAB_OPEN %>⚠️ 원장님 답변이 필요한 문의
         <% when App::ConfirmationsController::TAB_TEAM %>운영팀이 확인 중
         <% else %>처리 완료된 문의
         <% end %>
      <span class="text-xs font-normal text-slate-500">(<%= @handoffs.size %>건)</span>
    </h2>
  </header>

  <% if @handoffs.any? %>
    <ul class="divide-y divide-slate-100">
      <% @handoffs.each do |h| %>
        <li class="px-5 py-3 hover:bg-slate-50">
          <div class="flex items-center justify-between gap-3">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <span class="inline-block px-2 py-0.5 rounded text-xs font-medium
                  <%= case h.state
                      when 'open' then 'bg-amber-100 text-amber-700'
                      when 'acknowledged', 'operator_review' then 'bg-sky-100 text-sky-700'
                      else 'bg-slate-100 text-slate-600'
                      end %>">
                  <%= case h.state
                      when 'open' then '새로 도착'
                      when 'acknowledged' then '확인 중'
                      when 'operator_review' then '운영팀 검토'
                      when 'resolved', 'closed' then '처리 완료'
                      else h.state
                      end %>
                </span>
                <% if h.reason.present? %>
                  <span class="inline-block px-2 py-0.5 rounded bg-rose-100 text-rose-700 text-xs"><%= h.reason %></span>
                <% end %>
                <% if h.channel.present? %>
                  <span class="text-xs text-slate-400"><%= h.channel %></span>
                <% end %>
              </div>
              <% if @tab == App::ConfirmationsController::TAB_OPEN %>
                <p class="text-xs text-amber-800 italic mb-1">💡 <%= h.summary.presence || "원장님의 전문적인 판단이 필요합니다." %></p>
              <% end %>
              <p class="text-sm text-slate-900 truncate"><%= h.summary.presence || "원장님 확인이 필요합니다." %></p>
              <p class="text-xs text-slate-400 mt-0.5"><%= time_ago_in_words(h.created_at) %> 전</p>
            </div>
            <%= link_to "열기", app_handoff_path(h), class: "text-sm text-emerald-700 hover:underline whitespace-nowrap" %>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <%= render "shared/empty_state",
               icon: @tab == App::ConfirmationsController::TAB_OPEN ? "✅" : (@tab == App::ConfirmationsController::TAB_TEAM ? "🔧" : "📦"),
               title: case @tab
                      when App::ConfirmationsController::TAB_OPEN then "원장님 답변이 필요한 문의는 모두 처리되었습니다."
                      when App::ConfirmationsController::TAB_TEAM then "운영팀이 확인 중인 문의가 없습니다."
                      else "처리 완료된 문의가 여기에 표시됩니다."
                      end,
               body:  case @tab
                      when App::ConfirmationsController::TAB_OPEN then "새 문의가 도착하면 여기에 표시됩니다."
                      when App::ConfirmationsController::TAB_TEAM then "운영팀이 확인 중일 때 잠시 후 다시 확인해 주세요."
                      else "처리 완료된 문의는 30일간 보관됩니다."
                      end %>
  <% end %>
</section>

<%# ── ② 콘텐츠 검수 ── %>
<section class="mb-6 rounded-lg border border-slate-200 bg-white">
  <header class="flex items-center justify-between px-5 py-3 border-b border-slate-100">
    <h2 class="font-bold text-slate-900">
      <% case @tab
         when App::ConfirmationsController::TAB_OPEN %>📝 검수가 필요한 글
         <% when App::ConfirmationsController::TAB_TEAM %>운영팀이 검수 중
         <% else %>발행 완료 / 보관된 글
         <% end %>
      <span class="text-xs font-normal text-slate-500">(<%= @contents.size %>건)</span>
    </h2>
    <%= link_to "콘텐츠 캘린더로 →", app_content_items_path, class: "text-xs text-emerald-700 hover:underline" %>
  </header>

  <% if @contents.any? %>
    <ul class="divide-y divide-slate-100">
      <% @contents.each do |c| %>
        <li class="px-5 py-3 hover:bg-slate-50">
          <div class="flex items-center justify-between gap-3">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <span class="inline-block px-2 py-0.5 rounded text-xs font-medium bg-slate-100 text-slate-600"><%= c.state %></span>
                <% if c.target_channel_connection&.kind.present? %>
                  <span class="inline-block px-2 py-0.5 rounded bg-sky-100 text-sky-700 text-xs"><%= c.target_channel_connection.kind %></span>
                <% end %>
              </div>
              <p class="text-sm text-slate-900 truncate"><%= c.title %></p>
              <p class="text-xs text-slate-400 mt-0.5"><%= time_ago_in_words(c.created_at) %> 전</p>
            </div>
            <%= link_to "열기", app_edit_content_item_path(c), class: "text-sm text-emerald-700 hover:underline whitespace-nowrap" %>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="px-5 py-8 text-center text-sm text-slate-400">
      <% case @tab
         when App::ConfirmationsController::TAB_OPEN %>✅ 검수가 필요한 글이 없습니다.
         <% when App::ConfirmationsController::TAB_TEAM %>운영팀이 검수 중인 글이 없습니다.
         <% else %>완료된 글이 여기에 표시됩니다.
         <% end %>
    </div>
  <% end %>
</section>

<%# ── Discord CTA (§12) ── %>
<div class="mt-6 rounded-lg border border-emerald-200 bg-emerald-50 p-4 text-sm">
  <p class="font-medium text-emerald-900 mb-1">💬 Discord에서 소희와 대화하기</p>
  <p class="text-emerald-800">확인할 일에 대해 직접 이야기하고 싶으시면 Discord에서 소희에게 알려주세요.</p>
</div>