<% content_for(:title, "확인할 일 · 소희 프로젝트") %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold">📋 확인할 일</h1>
    <p class="text-xs text-slate-500 mt-0.5">원장님께서 한 번 봐주셔야 하는 항목들을 한 곳에 모았습니다.</p>
  </div>
</div>

<%# ── 4 카드 요약 ── %>
<div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
  <div class="rounded-lg <%= @counts[:handoff_open] > 0 ? 'bg-amber-50 border-2 border-amber-300' : 'bg-slate-50 border border-slate-200' %> p-4">
    <div class="text-2xl font-bold <%= @counts[:handoff_open] > 0 ? 'text-amber-700' : 'text-slate-400' %>"><%= @counts[:handoff_open] %></div>
    <div class="text-xs <%= @counts[:handoff_open] > 0 ? 'text-amber-700' : 'text-slate-500' %> mt-1 font-medium">새로 온 인계</div>
  </div>
  <div class="rounded-lg <%= @counts[:handoff_ack] > 0 ? 'bg-sky-50 border-2 border-sky-300' : 'bg-slate-50 border border-slate-200' %> p-4">
    <div class="text-2xl font-bold <%= @counts[:handoff_ack] > 0 ? 'text-sky-700' : 'text-slate-400' %>"><%= @counts[:handoff_ack] %></div>
    <div class="text-xs <%= @counts[:handoff_ack] > 0 ? 'text-sky-700' : 'text-slate-500' %> mt-1 font-medium">확인 중인 인계</div>
  </div>
  <div class="rounded-lg <%= @counts[:content_review] > 0 ? 'bg-rose-50 border-2 border-rose-300' : 'bg-slate-50 border border-slate-200' %> p-4">
    <div class="text-2xl font-bold <%= @counts[:content_review] > 0 ? 'text-rose-700' : 'text-slate-400' %>"><%= @counts[:content_review] %></div>
    <div class="text-xs <%= @counts[:content_review] > 0 ? 'text-rose-700' : 'text-slate-500' %> mt-1 font-medium">검수 대기 글</div>
  </div>
  <div class="rounded-lg bg-indigo-50 border border-indigo-200 p-4">
    <div class="text-2xl font-bold text-indigo-700"><%= @counts[:content_scheduled] %></div>
    <div class="text-xs text-indigo-700 mt-1 font-medium">예약 발행 글</div>
  </div>
</div>

<%# ── ① 사람 인계 ── %>
<section class="mb-6 rounded-lg border border-slate-200 bg-white">
  <header class="flex items-center justify-between px-5 py-3 border-b border-slate-100">
    <h2 class="font-bold text-slate-900 flex items-center gap-2">
      📞 사람 인계
      <span class="text-xs font-normal text-slate-500">(<%= @handoffs_open.size %>건)</span>
    </h2>
    <%= link_to "전체 보기 →", app_handoffs_path, class: "text-xs text-emerald-700 hover:underline" %>
  </header>

  <% if @handoffs_open.any? %>
    <ul class="divide-y divide-slate-100">
      <% @handoffs_open.each do |h| %>
        <li class="px-5 py-3 hover:bg-slate-50">
          <div class="flex items-center justify-between gap-3">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <span class="inline-block px-2 py-0.5 rounded text-xs font-medium
                  <%= case h.state
                      when 'open' then 'bg-amber-100 text-amber-700'
                      when 'acknowledged' then 'bg-sky-100 text-sky-700'
                      else 'bg-slate-100 text-slate-600'
                      end %>">
                  <%= case h.state
                      when 'open' then '새로 도착'
                      when 'acknowledged' then '확인 중'
                      else h.state
                      end %>
                </span>
                <span class="inline-block px-2 py-0.5 rounded bg-rose-100 text-rose-700 text-xs"><%= h.reason %></span>
                <span class="text-xs text-slate-400"><%= h.channel %></span>
              </div>
              <p class="text-sm text-slate-900 truncate"><%= h.summary %></p>
              <p class="text-xs text-slate-400 mt-0.5"><%= time_ago_in_words(h.created_at) %> 전</p>
            </div>
            <%= link_to "열기", app_handoff_path(h), class: "text-sm text-emerald-700 hover:underline whitespace-nowrap" %>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="px-5 py-8 text-center text-sm text-slate-400">
      ✅ 사람 인계가 없습니다. 모든 응대가 자동 처리되었어요.
    </div>
  <% end %>
</section>

<%# ── ② 콘텐츠 검수 ── %>
<section class="mb-6 rounded-lg border border-slate-200 bg-white">
  <header class="flex items-center justify-between px-5 py-3 border-b border-slate-100">
    <h2 class="font-bold text-slate-900 flex items-center gap-2">
      📝 검수 대기 중인 글
      <span class="text-xs font-normal text-slate-500">(<%= @pending_contents.size %>건)</span>
    </h2>
    <%= link_to "캘린더로 →", app_content_items_path, class: "text-xs text-emerald-700 hover:underline" %>
  </header>

  <% if @pending_contents.any? %>
    <ul class="divide-y divide-slate-100">
      <% @pending_contents.each do |c| %>
        <li class="px-5 py-3 hover:bg-slate-50">
          <div class="flex items-center justify-between gap-3">
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-slate-900 truncate"><%= c.title %></p>
              <p class="text-xs text-slate-500 mt-0.5">
                <%= c.target_channel_kind %> · <%= c.scheduled_at&.strftime("%Y-%m-%d %H:%M") || "예약 미정" %>
              </p>
            </div>
            <%= link_to "검수", edit_app_content_item_path(c), class: "text-sm text-emerald-700 hover:underline whitespace-nowrap" %>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="px-5 py-8 text-center text-sm text-slate-400">
      ✅ 검수 대기 중인 글이 없습니다.
    </div>
  <% end %>
</section>

<%# ── ③ 도움말 ── %>
<aside class="rounded-lg border border-emerald-200 bg-emerald-50 p-4 text-sm text-emerald-900">
  <p class="font-semibold mb-1">💡 도움말</p>
  <p class="text-xs leading-relaxed">
    사람 인계는 소희가 응대하지 못하는 항목(예약·환불·민원 등)입니다.
    검수 대기 중인 글은 발행 전 원장님의 톤·내용 확인이 필요한 항목입니다.
    처리 후에는 자동으로 "확인한 일"로 이동합니다.
  </p>
</aside>