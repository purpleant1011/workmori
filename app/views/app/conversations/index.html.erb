<% content_for :title, "문의 응대 · #{@current_account.name}" %>

<div class="flex items-center justify-between mb-4">
  <div>
    <h1 class="text-2xl font-bold">💬 문의 응대</h1>
    <p class="text-xs text-slate-500 mt-0.5">DM·댓글·당근·블로그 댓글 문의의 기초응대 / 사진 상담 / 원장님 인계 분류.</p>
  </div>
</div>

<%# ── 분류 요약 ── %>
<div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-5">
  <div class="rounded-lg border border-slate-200 bg-white p-3">
    <div class="text-xs text-slate-500">기초 안내 가능</div>
    <div class="text-2xl font-bold text-emerald-700"><%= @conversations.where(risk_level: "low").count %></div>
  </div>
  <div class="rounded-lg border border-slate-200 bg-white p-3">
    <div class="text-xs text-slate-500">사진 상담 요청</div>
    <div class="text-2xl font-bold text-sky-700"><%= @conversations.where(state: "open").where("customer_display_name LIKE ? OR customer_display_name LIKE ?", "%사진%", "%잔흔%").count %></div>
  </div>
  <div class="rounded-lg border-2 border-amber-300 bg-amber-50 p-3">
    <div class="text-xs text-amber-700">원장님 확인 필요</div>
    <div class="text-2xl font-bold text-amber-700"><%= @conversations.where(risk_level: "high").where(state: "open").count %></div>
  </div>
  <div class="rounded-lg border border-slate-200 bg-white p-3">
    <div class="text-xs text-slate-500">처리 완료</div>
    <div class="text-2xl font-bold text-slate-600"><%= @conversations.where(state: "closed").count %></div>
  </div>
</div>

<%# ── 진행 중 문의 ── %>
<div class="rounded-lg border border-slate-200 bg-white p-4 mb-4">
  <h2 class="font-bold text-slate-900 mb-3">진행 중 문의</h2>
  <% open_convs = @conversations.where(state: "open").order(last_message_at: :desc).limit(30) %>
  <% if open_convs.any? %>
    <ul class="divide-y divide-slate-100">
      <% open_convs.each do |c| %>
        <li class="py-3">
          <div class="flex items-start justify-between gap-3">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1">
                <span class="inline-block px-2 py-0.5 rounded text-xs font-medium
                  <%= case c.risk_level
                      when 'high' then 'bg-rose-100 text-rose-700'
                      when 'medium' then 'bg-amber-100 text-amber-700'
                      else 'bg-emerald-100 text-emerald-700'
                      end %>"><%= c.risk_level %></span>
                <span class="text-xs text-slate-500"><%= c.channel_kind %></span>
                <span class="text-xs text-slate-400"><%= c.customer_display_name %></span>
                <% if c.last_message_at %>
                  <span class="text-xs text-slate-400"><%= time_ago_in_words(c.last_message_at) %> 전</span>
                <% end %>
              </div>
              <p class="text-sm text-slate-900"><%= c.customer_display_name %></p>
            </div>
            <%= link_to "보기 →", app_conversation_path(c), class: "text-xs whitespace-nowrap px-3 py-1.5 bg-slate-100 hover:bg-slate-200 rounded" %>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-sm text-slate-400">진행 중인 문의가 없습니다.</p>
  <% end %>
</div>

<%# ── 처리 완료 ── %>
<div class="rounded-lg border border-slate-200 bg-white p-4">
  <h2 class="font-bold text-slate-700 mb-3">최근 처리 완료</h2>
  <% closed_convs = @conversations.where(state: "closed").order(last_message_at: :desc).limit(20) %>
  <% if closed_convs.any? %>
    <ul class="divide-y divide-slate-100">
      <% closed_convs.each do |c| %>
        <li class="py-2 text-sm flex items-center justify-between">
          <div>
            <span class="text-slate-700"><%= c.customer_display_name %></span>
            <span class="text-xs text-slate-500 ml-2"><%= c.channel_kind %></span>
          </div>
          <span class="text-xs text-slate-400"><%= c.last_message_at&.strftime("%m/%d %H:%M") %></span>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-sm text-slate-400">처리 완료된 문의가 없습니다.</p>
  <% end %>
</div>