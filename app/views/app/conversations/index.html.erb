<% content_for :title, "고객 문의 · #{@current_account.name}" %>

<%# ── 명세 §9: 3 탭 통합 (원장님 답변 필요 / 소희가 처리 / 처리 완료) ── %>
<div class="mb-6">
  <h1 class="text-2xl font-bold text-slate-900">고객 문의</h1>
  <p class="text-xs text-slate-500 mt-1">DM·댓글·당근·블로그 댓글 문의의 기초 응대·사진 상담·원장님 답변 분류.</p>
</div>

<div class="mb-6 border-b border-slate-200">
  <nav class="flex gap-1">
    <% [
      [App::ConversationsController::TAB_NEED,  "원장님 답변 필요", @counts[:need]],
      [App::ConversationsController::TAB_SOHEE, "소희가 처리",      @counts[:sohee]],
      [App::ConversationsController::TAB_DONE,  "처리 완료",        @counts[:done]]
    ].each do |key, label, count| %>
      <%= link_to app_conversations_path(tab: key),
            class: "px-4 py-2.5 text-sm font-medium border-b-2 -mb-px #{@tab == key ? 'border-emerald-500 text-emerald-700' : 'border-transparent text-slate-500 hover:text-slate-700 hover:border-slate-300'}" do %>
        <%= label %>
        <% if count.to_i > 0 %>
          <span class="ml-1.5 inline-flex items-center justify-center px-2 py-0.5 rounded-full <%= @tab == key ? 'bg-emerald-100 text-emerald-700' : 'bg-slate-100 text-slate-600' %> text-xs"><%= count %></span>
        <% end %>
      <% end %>
    <% end %>
  </nav>
</div>

<% if @conversations.any? %>
  <div class="space-y-3">
    <% @conversations.each do |c| %>
      <article class="rounded-lg border border-slate-200 bg-white p-4 hover:shadow-sm transition">
        <header class="flex items-start justify-between mb-2">
          <div class="flex items-center gap-2">
            <span class="inline-block px-2 py-0.5 rounded text-xs font-medium
              <%= case c.risk_level
                  when 'high'   then 'bg-rose-100 text-rose-700'
                  when 'medium' then 'bg-amber-100 text-amber-700'
                  else 'bg-emerald-100 text-emerald-700'
                  end %>">
              <%= case c.risk_level
                  when 'high'   then '전문 판단 필요'
                  when 'medium' then '확인 후 응대'
                  else '기초 안내'
                  end %>
            </span>
            <% if c.channel_kind.present? %>
              <span class="inline-block px-2 py-0.5 rounded bg-slate-100 text-slate-600 text-xs"><%= c.channel_kind %></span>
            <% end %>
          </div>
          <span class="text-xs text-slate-400 whitespace-nowrap"><%= time_ago_in_words(c.updated_at) %> 전</span>
        </header>
        <h3 class="font-semibold text-slate-900 mb-1">
          <% if @tab == App::ConversationsController::TAB_NEED %>
            ⚠️ 시술 가능 여부를 묻는 질문이어서 원장님의 전문적인 판단이 필요합니다.
          <% else %>
            <%= c.messages.order(created_at: :desc).first&.body&.truncate(80) || "고객 문의 ##{c.id}" %>
          <% end %>
        </h3>
        <p class="text-xs text-slate-600 line-clamp-2 mb-3"><%= c.messages.order(created_at: :desc).first&.body&.truncate(150) %></p>
        <div class="flex items-center justify-between text-xs">
          <span class="text-slate-400"><%= c.customer_display_name.presence || "익명" %></span>
          <div class="flex gap-2">
            <%= link_to "열기", app_conversation_path(c), class: "text-emerald-700 hover:underline font-medium" %>
            <% if @tab == App::ConversationsController::TAB_NEED %>
              <%= link_to "직접 답변", app_conversation_path(c), class: "text-amber-700 hover:underline font-medium" %>
            <% end %>
          </div>
        </div>
      </article>
    <% end %>
  </div>
<% else %>
  <%= render "shared/empty_state",
             icon: @tab == App::ConversationsController::TAB_NEED ? "✅" : (@tab == App::ConversationsController::TAB_SOHEE ? "💬" : "📦"),
             title: case @tab
                    when App::ConversationsController::TAB_NEED  then "원장님 답변이 필요한 문의가 없습니다."
                    when App::ConversationsController::TAB_SOHEE then "소희가 처리 중인 문의가 없습니다."
                    else "처리 완료된 문의가 여기에 표시됩니다."
                    end,
             body: "새 문의가 도착하면 여기에 표시됩니다." %>
<% end %>