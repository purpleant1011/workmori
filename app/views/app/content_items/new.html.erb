<% content_for :title, "새 콘텐츠 생성" %>
<div class="max-w-2xl mx-auto p-6">
  <h1 class="text-2xl font-bold mb-4">✨ 새 콘텐츠 생성</h1>
  <p class="text-sm text-gray-600 mb-6">AI 직원이 사업장 정보와 최근 대화 기억을 바탕으로 초안을 만듭니다. 안전 검증 결과에 따라 자동 발행되거나 검수를 요청합니다.</p>

  <%= form_with url: app_generate_content_item_path, method: :post, local: true, class: "space-y-4" do %>
    <div>
      <label class="block text-sm font-medium mb-1">AI 직원</label>
      <select name="ai_employee_id" class="w-full border rounded px-3 py-2">
        <% @ai_employees.each do |ae| %>
          <option value="<%= ae.id %>"><%= ae.name %> (<%= ae.role_label %>)</option>
        <% end %>
      </select>
    </div>

    <div>
      <label class="block text-sm font-medium mb-1">콘텐츠 종류</label>
      <select name="intent" class="w-full border rounded px-3 py-2">
        <%
          kind_labels = {
            "feed"         => "📝 인스타그램 피드",
            "reel_script"  => "🎬 릴스 스크립트",
            "blog"         => "📰 블로그 글",
            "thread"       => "🧵 스레드 글",
            "place_post"   => "📍 네이버 플레이스",
            "daangn_post"  => "🦄 당근마켓 글",
            "cardnews"     => "🃏 카드뉴스",
            "shortform"    => "📱 숏폼 영상"
          }
        %>
        <% @intents.each do |k| %>
          <option value="<%= k %>" <%= "selected" if k == "feed" %>><%= kind_labels[k] || k %></option>
        <% end %>
      </select>
    </div>

    <div>
      <label class="block text-sm font-medium mb-1">발행 방식</label>
      <select name="schedule_kind" class="w-full border rounded px-3 py-2">
        <option value="manual">✅ 검수 후 수동 발행 (안전)</option>
        <option value="now">⚡ 지금 즉시 발행</option>
        <option value="tick">⏱️ 30분 뒤 발행</option>
      </select>
      <p class="text-xs text-gray-500 mt-1">권장: 검수 후 수동 발행. 즉시 발행은 검수 없이 나가니 신중히 선택해 주세요.</p>
    </div>

    <div class="flex gap-2">
      <button class="bg-indigo-600 text-white px-4 py-2 rounded">생성</button>
      <a class="px-4 py-2 rounded border" href="<%= app_content_items_path %>">취소</a>
    </div>
  <% end %>
</div>
