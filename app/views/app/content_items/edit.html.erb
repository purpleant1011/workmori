<% content_for :title, "콘텐츠 수정" %>
<div class="max-w-3xl mx-auto p-6">
  <h1 class="text-2xl font-bold mb-4">✏️ 콘텐츠 수정</h1>
  <p class="text-sm text-gray-600 mb-6">본문/캡션을 수정한 뒤 저장하면 새 버전이 기록되고 안전 검증이 다시 실행됩니다.</p>

  <%= form_with model: @content, url: app_update_content_item_path(@content), method: :patch, local: true, class: "space-y-4" do |f| %>
    <div>
      <label class="block text-sm font-medium mb-1">제목</label>
      <%= f.text_field :title, class: "w-full border rounded px-3 py-2" %>
    </div>
    <div>
      <label class="block text-sm font-medium mb-1">본문</label>
      <%= f.text_area :body, rows: 10, class: "w-full border rounded px-3 py-2 font-mono text-sm" %>
    </div>
    <div>
      <label class="block text-sm font-medium mb-1">캡션</label>
      <%= f.text_area :caption, rows: 3, class: "w-full border rounded px-3 py-2" %>
    </div>
    <div class="flex gap-2">
      <button class="bg-indigo-600 text-white px-4 py-2 rounded">저장</button>
      <a class="px-4 py-2 rounded border" href="<%= app_content_item_path(@content) %>">취소</a>
    </div>
  <% end %>
</div>
