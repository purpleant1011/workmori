<% content_for :title, @content.title %>
<%
  content_state_labels = {
    "draft"        => "초안",
    "generated"    => "생성됨",
    "needs_review" => "검수 요청",
    "approved"     => "승인됨",
    "scheduled"    => "예약됨",
    "published"    => "발행 완료",
    "failed"       => "발행 실패",
    "archived"     => "보관됨"
  }
  safety_state_labels = {
    "passed"       => "✅ 안전",
    "warning"      => "⚠️ 주의 필요",
    "blocked"      => "🚫 차단",
    "pending"      => "⏳ 검사 중"
  }
  kind_labels = {
    "feed"         => "📝 인스타그램 피드",
    "reel_script"  => "🎬 릴스 스크립트",
    "blog"         => "📰 블로그 글",
    "thread"       => "🧵 스레드 글",
    "place_post"   => "📍 네이버 플레이스",
    "daangn_post"  => "🦄 당근마켓 글",
    "cardnews"     => "🃏 카드뉴스",
    "shortform"    => "📱 숏폼 영상"
  }
  approval_state_labels = {
    "pending"  => "검수 대기",
    "approved" => "승인됨",
    "rejected" => "반려됨",
    "expired"  => "기간 만료"
  }
  attempt_state_labels = {
    "succeeded" => "성공",
    "failed"    => "실패",
    "queued"    => "대기 중",
    "running"   => "진행 중"
  }
%>
<div class="max-w-4xl mx-auto p-6 space-y-4">
  <div class="flex items-center justify-between">
    <div>
      <a class="text-xs text-gray-500" href="<%= app_content_items_path %>">← 목록</a>
      <h1 class="text-2xl font-bold mt-1"><%= @content.title %></h1>
      <p class="text-xs text-gray-500 mt-1">
        <span class="px-2 py-0.5 rounded <%= @content.state == 'published' ? 'bg-emerald-100 text-emerald-700' : (@content.state == 'failed' ? 'bg-rose-100 text-rose-700' : 'bg-gray-100 text-gray-700') %>">
          <%= content_state_labels[@content.state] || @content.state %>
        </span>
        ·
        <span class="px-2 py-0.5 rounded <%= @content.safety_state == 'passed' ? 'bg-emerald-50 text-emerald-700' : (@content.safety_state == 'blocked' ? 'bg-rose-100 text-rose-700' : 'bg-amber-50 text-amber-700') %>">
          안전 검증: <%= safety_state_labels[@content.safety_state] || @content.safety_state %>
        </span>
        ·
        <span class="text-gray-600"><%= kind_labels[@content.content_kind] || @content.content_kind %></span>
      </p>
    </div>
    <div class="flex gap-2">
      <a class="px-3 py-2 rounded border text-sm" href="<%= app_edit_content_item_path(@content) %>">수정</a>
      <% if %w[needs_review generated].include?(@content.state) %>
        <form action="<%= app_approve_content_item_path(@content) %>" method="post" class="inline">
          <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
          <button class="px-3 py-2 rounded bg-emerald-600 text-white text-sm">승인+발행</button>
        </form>
        <form action="<%= app_reject_content_item_path(@content) %>" method="post" class="inline">
          <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
          <button class="px-3 py-2 rounded bg-rose-600 text-white text-sm">반려</button>
        </form>
      <% end %>
      <% if @content.state == "scheduled" %>
        <form action="<%= app_publish_content_item_path(@content) %>" method="post" class="inline">
          <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
          <button class="px-3 py-2 rounded bg-indigo-600 text-white text-sm">지금 발행</button>
        </form>
      <% end %>
      <form action="<%= app_archive_content_item_path(@content) %>" method="post" class="inline">
        <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
        <button class="px-3 py-2 rounded border text-sm">보관</button>
      </form>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="md:col-span-2 bg-white border rounded p-4 space-y-3">
      <div>
        <h2 class="text-xs font-semibold text-gray-500 mb-1">본문</h2>
        <pre class="whitespace-pre-wrap text-sm font-mono"><%= @content.body %></pre>
      </div>
      <div>
        <h2 class="text-xs font-semibold text-gray-500 mb-1">캡션</h2>
        <p class="text-sm whitespace-pre-wrap"><%= @content.caption %></p>
      </div>
      <div>
        <h2 class="text-xs font-semibold text-gray-500 mb-1">해시태그</h2>
        <p class="text-sm font-mono"><%= @content.hashtags_json %></p>
      </div>
      <div>
        <h2 class="text-xs font-semibold text-gray-500 mb-1">대상 채널</h2>
        <p class="text-sm">
          <% case @content.target_channel_kind
             when "instagram_feed" then "📷 인스타그램 피드"
             when "instagram_reel" then "🎬 인스타그램 릴스"
             when "blog_naver"     then "📰 네이버 블로그"
             when "thread_x"       then "🧵 X(트위터)"
             when "place_naver"    then "📍 네이버 플레이스"
             when "daangn"         then "🦄 당근마켓"
             when "threads_meta"   then "🧵 Meta 스레드"
             when "shortform_tiktok" then "🎵 틱톡"
             else @content.target_channel_kind
             end %>
        </p>
      </div>
    </div>

    <div class="space-y-4">
      <div class="bg-white border rounded p-4">
        <h2 class="text-xs font-semibold text-gray-500 mb-2">예약 / 발행 시간</h2>
        <p class="text-sm">예약: <%= @content.scheduled_at&.strftime("%Y-%m-%d %H:%M") || "—" %></p>
        <p class="text-sm">발행: <%= @content.published_at&.strftime("%Y-%m-%d %H:%M") || "아직 발행 전" %></p>
        <% if @content.published_external_url.present? %>
          <p class="text-sm mt-1">📎 발행된 글: <a class="text-indigo-600 underline" target="_blank" href="<%= @content.published_external_url %>"><%= @content.published_external_url %></a></p>
        <% end %>
        <form action="<%= app_schedule_content_item_path(@content) %>" method="post" class="mt-3 flex gap-2">
          <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
          <input type="datetime-local" name="scheduled_at" class="border rounded px-2 py-1 text-sm flex-1">
          <button class="px-3 py-1 text-sm rounded bg-gray-800 text-white">예약</button>
        </form>
      </div>

      <% active_channels = @current_account.channel_connections.where(status: "active") %>
      <% if active_channels.any? && %w[generated approved scheduled].include?(@content.state) %>
        <div class="bg-white border rounded p-4">
          <h2 class="text-xs font-semibold text-gray-500 mb-2">채널 직접 게시</h2>
          <% active_channels.each do |ch| %>
            <form action="/app/content/items/<%= @content.id %>/publish_to_channel" method="post" class="flex items-center gap-2 mb-2">
              <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
              <input type="hidden" name="channel_id" value="<%= ch.id %>">
              <span class="text-sm font-medium flex-1"><%= ch.kind.humanize %></span>
              <button class="px-3 py-1 text-sm rounded bg-indigo-600 text-white">게시</button>
            </form>
          <% end %>
        </div>
      <% end %>

      <% if @approval %>
        <div class="bg-amber-50 border border-amber-200 rounded p-4">
          <h2 class="text-xs font-semibold text-amber-700 mb-2">검수 요청</h2>
          <p class="text-sm">
            <span class="px-2 py-0.5 rounded bg-white border border-amber-200"><%= approval_state_labels[@approval.state] || @approval.state %></span>
          </p>
          <p class="text-xs text-gray-600 mt-1">마감: <%= @approval.expires_at&.strftime("%Y-%m-%d %H:%M") || "—" %></p>
          <% if @approval.decision_notes.present? %>
            <p class="text-xs text-gray-600 mt-1">메모: <%= @approval.decision_notes %></p>
          <% end %>
        </div>
      <% end %>

      <div class="bg-white border rounded p-4">
        <h2 class="text-xs font-semibold text-gray-500 mb-2">안전 검증 요약</h2>
        <% safety = @content.safety_notes || {} %>
        <% if safety.any? %>
          <ul class="text-xs text-gray-700 space-y-1">
            <% if safety["verdict"] %><li>판정: <strong><%= safety["verdict"] %></strong></li><% end %>
            <% if safety["reasons"].is_a?(Array) && safety["reasons"].any? %>
              <li>사유: <%= safety["reasons"].join(", ") %></li>
            <% end %>
            <% if safety["checked_at"] %><li>검사 시각: <%= safety["checked_at"] %></li><% end %>
          </ul>
        <% else %>
          <p class="text-xs text-gray-400">아직 안전 검증이 끝나지 않았습니다.</p>
        <% end %>
      </div>

      <% if @attempts.any? %>
        <div class="bg-white border rounded p-4">
          <h2 class="text-xs font-semibold text-gray-500 mb-2">발행 시도 (<%= @attempts.size %>회)</h2>
          <ul class="space-y-1">
            <% @attempts.each do |a| %>
              <li class="text-xs">
                <span class="<%= a.state == "succeeded" ? "text-emerald-600" : (a.state == "failed" ? "text-rose-600" : "text-gray-600") %>">
                  <%= attempt_state_labels[a.state] || a.state %>
                </span>
                ·
                <%= a.attempts %>번째 시도
                · <%= a.created_at.strftime("%m-%d %H:%M") %>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <% if @versions && @versions.size > 1 %>
        <div class="bg-white border rounded p-4">
          <h2 class="text-xs font-semibold text-gray-500 mb-2">수정 이력 (<%= @versions.size %>회)</h2>
          <ul class="space-y-1">
            <% @versions.each do |v| %>
              <li class="text-xs">v<%= v.version_number %> · <%= v.created_at.strftime("%m-%d %H:%M") %><%= " · 변경자=#{User.find_by(id: v.changed_by_user_id)&.name}" if v.changed_by_user_id %></li>
            <% end %>
          </ul>
        </div>
      <% end %>
    </div>
  </div>