<% content_for :title, "콘텐츠 캘린더" %>
<div class="max-w-6xl mx-auto p-6 space-y-4">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold">📅 콘텐츠 캘린더</h1>
      <p class="text-sm text-gray-500">최근 생성된 콘텐츠 100건 · <%= link_to "원장님 검수 큐 →", "/app/content", class: "text-amber-700 hover:underline" %></p>
    </div>
    <a class="px-4 py-2 rounded bg-indigo-600 text-white" href="<%= app_new_content_item_path %>">+ 새 콘텐츠 생성</a>
  </div>

  <%# ── 5단계 상태 보드 ── %>
  <% state_counts = {
    generated:   @current_account.content_items.where(state: "generated").count,
    needs_review: @current_account.content_items.where(state: "needs_review").count,
    approved:    @current_account.content_items.where(state: "approved").count,
    scheduled:   @current_account.content_items.where(state: %w[scheduled published]).count,
    failed:      @current_account.content_items.where(state: "failed").count
  } %>
  <div class="grid grid-cols-5 gap-3">
    <div class="rounded-lg border-2 border-slate-300 bg-slate-50 p-3">
      <div class="text-xs text-slate-500">🧪 생성</div>
      <div class="text-2xl font-bold text-slate-900"><%= state_counts[:generated] %></div>
    </div>
    <div class="rounded-lg border-2 border-amber-300 bg-amber-50 p-3">
      <div class="text-xs text-amber-700">🔎 검수 대기</div>
      <div class="text-2xl font-bold text-amber-900"><%= state_counts[:needs_review] %></div>
    </div>
    <div class="rounded-lg border-2 border-emerald-300 bg-emerald-50 p-3">
      <div class="text-xs text-emerald-700">✅ 승인</div>
      <div class="text-2xl font-bold text-emerald-900"><%= state_counts[:approved] %></div>
    </div>
    <div class="rounded-lg border-2 border-sky-300 bg-sky-50 p-3">
      <div class="text-xs text-sky-700">📤 게시·예약</div>
      <div class="text-2xl font-bold text-sky-900"><%= state_counts[:scheduled] %></div>
    </div>
    <div class="rounded-lg border-2 border-rose-300 bg-rose-50 p-3">
      <div class="text-xs text-rose-700">⚠️ 실패</div>
      <div class="text-2xl font-bold text-rose-900"><%= state_counts[:failed] %></div>
    </div>
  </div>

  <div class="rounded-lg border border-slate-200 bg-slate-50 p-3 text-xs text-slate-700 grid grid-cols-2 md:grid-cols-4 gap-3">
    <div>
      <strong class="text-slate-900">🧪 생성 (generated)</strong>
      <p class="mt-0.5">소희가 초안 작성</p>
    </div>
    <div>
      <strong class="text-amber-700">🔎 검수 (pending_review)</strong>
      <p class="mt-0.5">원장님 확인 대기</p>
    </div>
    <div>
      <strong class="text-emerald-700">✅ 승인 (approved)</strong>
      <p class="mt-0.5">게시 OK — 합격 누적</p>
    </div>
    <div>
      <strong class="text-sky-700">📤 게시 (scheduled/posted)</strong>
      <p class="mt-0.5">채널 발행 완료</p>
    </div>
  </div>

  <% if @contents.empty? %>
    <p class="text-gray-500 p-8 text-center border rounded">아직 콘텐츠가 없습니다. 새 콘텐츠를 생성해 보세요.</p>
  <% else %>
    <%
      state_labels = {
        "draft"        => "초안",
        "generated"    => "생성됨",
        "needs_review" => "검수 요청",
        "approved"     => "승인됨",
        "scheduled"    => "예약됨",
        "published"    => "발행 완료",
        "failed"       => "발행 실패",
        "archived"     => "보관됨"
      }
      safety_labels = {
        "passed"  => "✅ 안전",
        "warning" => "⚠️ 주의",
        "blocked" => "🚫 차단",
        "pending" => "⏳ 검사 중"
      }
      kind_labels = {
        "feed"         => "📷 인스타 피드",
        "reel_script"  => "🎬 릴스",
        "blog"         => "📰 블로그",
        "thread"       => "🧵 스레드",
        "place_post"   => "📍 플레이스",
        "daangn_post"  => "🦄 당근",
        "cardnews"     => "🃏 카드뉴스",
        "shortform"    => "📱 숏폼"
      }
    %>
    <table class="w-full text-sm border-collapse">
      <thead>
        <tr class="bg-gray-50 text-left">
          <th class="border p-2">제목</th>
          <th class="border p-2">상태</th>
          <th class="border p-2">안전 검증</th>
          <th class="border p-2">종류</th>
          <th class="border p-2">생성일</th>
        </tr>
      </thead>
      <tbody>
        <% @contents.each do |c| %>
          <tr class="hover:bg-gray-50">
            <td class="border p-2">
              <a class="text-indigo-700 hover:underline" href="<%= app_content_item_path(c) %>"><%= c.title %></a>
            </td>
            <td class="border p-2 text-xs">
              <span class="px-2 py-0.5 rounded <%= c.state == 'published' ? 'bg-emerald-100 text-emerald-700' : (c.state == 'failed' ? 'bg-rose-100 text-rose-700' : 'bg-gray-100 text-gray-700') %>">
                <%= state_labels[c.state] || c.state %>
              </span>
            </td>
            <td class="border p-2 text-xs">
              <span class="px-2 py-0.5 rounded <%= c.safety_state == 'passed' ? 'bg-emerald-50 text-emerald-700' : (c.safety_state == 'blocked' ? 'bg-rose-100 text-rose-700' : 'bg-amber-50 text-amber-700') %>">
                <%= safety_labels[c.safety_state] || c.safety_state %>
              </span>
            </td>
            <td class="border p-2 text-xs"><%= kind_labels[c.content_kind] || c.content_kind %></td>
            <td class="border p-2 text-xs"><%= c.created_at.strftime("%m-%d %H:%M") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>
