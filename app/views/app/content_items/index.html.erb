<% content_for :title, "콘텐츠 캘린더 · 소희 프로젝트" %>

<%# ── 명세 §8: 4 탭 통합 (확인 필요 / 게시 예정 / 게시 완료 / 보관) + 카드 UI ── %>
<%
  tab = params[:tab].presence_in(%w[review scheduled published archived]) || "review"
  filter_map = {
    "review"    => %w[needs_review generated],
    "scheduled" => %w[scheduled approved],
    "published" => %w[published],
    "archived"  => %w[archived rejected]
  }
  states_for_tab = filter_map[tab]
  contents = @current_account.content_items.where(state: states_for_tab).order(created_at: :desc).limit(60)
  counts = {
    review:    @current_account.content_items.where(state: filter_map["review"]).count,
    scheduled: @current_account.content_items.where(state: filter_map["scheduled"]).count,
    published: @current_account.content_items.where(state: filter_map["published"]).count,
    archived:  @current_account.content_items.where(state: filter_map["archived"]).count
  }
%>

<div class="mb-6 flex items-center justify-between">
  <div>
    <h1 class="text-2xl font-bold text-slate-900">콘텐츠</h1>
    <p class="text-xs text-slate-500 mt-1">소희가 준비한 콘텐츠를 상태별로 확인하세요.</p>
  </div>
  <%= link_to "+ 새 콘텐츠 요청", app_new_content_item_path, class: "px-4 py-2 rounded-md bg-emerald-600 text-white font-semibold hover:bg-emerald-700 text-sm" %>
</div>

<%# ── 4 탭 네비게이션 ── %>
<div class="mb-6 border-b border-slate-200">
  <nav class="flex gap-1">
    <% [
      ["review",    "확인 필요", counts[:review]],
      ["scheduled", "게시 예정", counts[:scheduled]],
      ["published", "게시 완료", counts[:published]],
      ["archived",  "보관",      counts[:archived]]
    ].each do |key, label, count| %>
      <%= link_to app_content_items_path(tab: key),
            class: "px-4 py-2.5 text-sm font-medium border-b-2 -mb-px #{tab == key ? 'border-emerald-500 text-emerald-700' : 'border-transparent text-slate-500 hover:text-slate-700 hover:border-slate-300'}" do %>
        <%= label %>
        <% if count.to_i > 0 %>
          <span class="ml-1.5 inline-flex items-center justify-center px-2 py-0.5 rounded-full <%= tab == key ? 'bg-emerald-100 text-emerald-700' : 'bg-slate-100 text-slate-600' %> text-xs"><%= count %></span>
        <% end %>
      <% end %>
    <% end %>
  </nav>
</div>

<%# ── 카드 UI ── %>
<% if contents.any? %>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    <% contents.each do |c| %>
      <article class="rounded-lg border border-slate-200 bg-white p-4 hover:shadow-sm transition">
        <div class="flex items-start justify-between mb-2">
          <div class="flex items-center gap-1.5">
            <% kind = c.channel_connection&.kind %>
            <span class="inline-block px-2 py-0.5 rounded text-xs font-medium
              <%= case kind
                  when 'instagram' then 'bg-pink-100 text-pink-700'
                  when 'threads'   then 'bg-slate-100 text-slate-700'
                  when 'naver_blog' then 'bg-emerald-100 text-emerald-700'
                  else 'bg-slate-100 text-slate-600'
                  end %>">
              <%= case kind
                  when 'instagram' then 'Instagram'
                  when 'threads'   then 'Threads'
                  when 'naver_blog' then 'Naver Blog'
                  else (kind.presence || '채널 미지정')
                  end %>
            </span>
            <span class="inline-block px-2 py-0.5 rounded bg-slate-100 text-slate-600 text-xs"><%= c.state %></span>
          </div>
          <span class="text-xs text-slate-400 whitespace-nowrap"><%= c.scheduled_at&.strftime("%m/%d %H:%M") || time_ago_in_words(c.created_at) + " 전" %></span>
        </div>
        <h3 class="font-semibold text-slate-900 mb-1 line-clamp-2"><%= c.title %></h3>
        <% if c.body.present? %>
          <p class="text-xs text-slate-600 line-clamp-3 mb-3"><%= c.body %></p>
        <% end %>
        <div class="flex items-center justify-between text-xs">
          <span class="text-slate-400"><%= c.content_versions.count %>개 버전</span>
          <div class="flex gap-2">
            <%= link_to "열기", edit_app_content_item_path(c), class: "text-emerald-700 hover:underline font-medium" %>
            <% if tab == "review" %>
              <%= button_to "승인", app_content_item_path(c), method: :patch, params: { content_item: { state: "approved" } }, class: "text-emerald-700 hover:underline font-medium" %>
            <% end %>
          </div>
        </div>
      </article>
    <% end %>
  </div>
<% else %>
  <div class="rounded-lg border border-slate-200 bg-white p-12 text-center">
    <p class="text-sm text-slate-500">
      <% case tab
         when "review" %>확인이 필요한 콘텐츠가 없습니다.
         <% when "scheduled" %>게시 예정인 콘텐츠가 없습니다.
         <% when "published" %>아직 게시 완료된 콘텐츠가 없습니다.
         <% else %>보관된 콘텐츠가 없습니다.
         <% end %>
    </p>
    <p class="text-xs text-slate-400 mt-2">소희가 매일 자동으로 콘텐츠를 준비하고 있습니다.</p>
  </div>
<% end %>