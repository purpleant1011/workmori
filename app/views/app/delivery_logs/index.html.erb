<% content_for :title do %>배달 이력<% end %>
<div class="px-6 py-8 max-w-5xl mx-auto">
  <h1 class="text-2xl font-semibold text-gray-900 mb-6">📬 배달 이력</h1>
  <% if @deliveries.any? %>
    <table class="min-w-full bg-white shadow rounded-lg text-sm">
      <thead class="bg-gray-50">
        <tr>
          <th class="text-left px-3 py-2">시각</th>
          <th class="text-left px-3 py-2">종류</th>
          <th class="text-left px-3 py-2">제목</th>
          <th class="text-right px-3 py-2">수신</th>
          <th class="text-left px-3 py-2">미리보기</th>
        </tr>
      </thead>
      <tbody>
        <% @deliveries.each do |d| %>
          <tr class="border-t">
            <td class="px-3 py-2 text-xs"><%= d.delivered_at&.strftime("%Y-%m-%d %H:%M") %></td>
            <td class="px-3 py-2"><span class="px-2 py-0.5 text-xs bg-gray-100 rounded"><%= d.kind %></span></td>
            <td class="px-3 py-2"><%= d.subject %></td>
            <td class="px-3 py-2 text-right"><%= d.recipient_count %></td>
            <td class="px-3 py-2 text-xs text-gray-500 max-w-md truncate"><%= d.body_excerpt %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-sm text-gray-400">배달 이력이 없습니다.</p>
  <% end %>
</div>
