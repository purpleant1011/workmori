<% content_for :title, "청구서" %>
<% krw = ->(n) { n.to_i.to_s.reverse.scan(/\d{1,3}/).join(",").reverse } %>
<% if @invoice %>
  <div class="max-w-3xl mx-auto p-6 space-y-5">
    <div class="flex items-center justify-between">
      <h1 class="text-2xl font-bold">청구서 <%= @invoice.invoice_number %></h1>
      <span class="text-sm px-3 py-1 rounded-full <%= @invoice.state == 'paid' ? 'bg-emerald-100 text-emerald-700' : 'bg-amber-100 text-amber-700' %>"><%= @invoice.state %></span>
    </div>

    <div class="rounded-xl border border-slate-200 bg-white p-5 space-y-2">
      <p><span class="text-slate-500">청구 기간:</span> <%= @invoice.billing_period_start %> ~ <%= @invoice.billing_period_end %></p>
      <p><span class="text-slate-500">발행일:</span> <%= @invoice.issued_on %></p>
      <p><span class="text-slate-500">결제 기한:</span> <%= @invoice.due_on %></p>
      <p><span class="text-slate-500">결제 완료일:</span> <%= @invoice.paid_on || "미결제" %></p>
      <hr>
      <p>공급가액: <%= krw.call(@invoice.supply_amount_krw) %>원</p>
      <p>부가세: <%= krw.call(@invoice.vat_amount_krw) %>원</p>
      <p class="text-lg font-bold">최종 금액: <%= krw.call(@invoice.final_amount_krw) %>원</p>
    </div>

    <% if @invoice.state != "paid" %>
      <div class="rounded-xl border border-amber-300 bg-amber-50 p-5">
        <p class="font-semibold mb-2">결제 진행</p>
        <p class="text-sm text-slate-600 mb-3">TossPayments 모의 게이트웨이를 통해 즉시 결제할 수 있습니다.</p>
        <%= button_to "지금 #{krw.call(@invoice.final_amount_krw)}원 결제 (TossMock)", app_billing_pay_path(invoice_id: @invoice.id), method: :post, class: "w-full px-4 py-3 bg-emerald-600 text-white rounded-md hover:bg-emerald-700" %>
      </div>
    <% else %>
      <p class="text-emerald-600 text-sm">이 청구서는 결제 완료되었습니다.</p>
    <% end %>
  </div>
<% else %>
  <p class="p-6">청구서를 찾을 수 없습니다.</p>
<% end %>
