<%# ── 헤더 ── %>
<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold">🌸 오늘의 운영실</h1>
    <p class="text-xs text-slate-500 mt-0.5"><%= @current_account.name %> · <%= Time.current.strftime("%Y년 %m월 %d일 %A") %></p>
  </div>
  <div class="text-sm space-x-2">
    <%= link_to "최근 7일",  app_root_path(range: "7d"),  class: ("font-bold underline" if @range == "7d") %>
    <%= link_to "최근 30일", app_root_path(range: "30d"), class: ("font-bold underline" if @range == "30d") %>
    <%= link_to "최근 90일", app_root_path(range: "90d"), class: ("font-bold underline" if @range == "90d") %>
  </div>
</div>

<%# ── ① 오늘 핵심 4 카드 ── %>
<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
  <div class="rounded-lg bg-emerald-50 border-2 border-emerald-200 p-4">
    <div class="text-3xl font-bold text-emerald-700"><%= @today[:contents_generated] %></div>
    <div class="text-sm text-emerald-800 mt-1 font-medium">오늘 작성한 글</div>
    <div class="text-xs text-emerald-600 mt-0.5">예약 <%= @today[:contents_scheduled] %>건 · 발행 완료 <%= @today[:contents_published] || 0 %>건</div>
  </div>
  <div class="rounded-lg bg-sky-50 border-2 border-sky-200 p-4">
    <div class="text-3xl font-bold text-sky-700"><%= @today[:conversations_handled] %></div>
    <div class="text-sm text-sky-800 mt-1 font-medium">오늘 응대한 문의</div>
    <div class="text-xs text-sky-600 mt-0.5">단순 응대 <%= @today[:inquiries_basics_answered] %>건</div>
  </div>
  <div class="rounded-lg <%= @today[:handoffs_open] > 0 ? 'bg-amber-50 border-2 border-amber-300' : 'bg-slate-50 border border-slate-200' %> p-4">
    <div class="text-3xl font-bold <%= @today[:handoffs_open] > 0 ? 'text-amber-700' : 'text-slate-400' %>"><%= @today[:handoffs_open] %></div>
    <div class="text-sm <%= @today[:handoffs_open] > 0 ? 'text-amber-800' : 'text-slate-500' %> mt-1 font-medium">원장님 확인 필요</div>
    <div class="text-xs <%= @today[:handoffs_open] > 0 ? 'text-amber-600' : 'text-slate-400' %> mt-0.5">
      <%= link_to "확인하러 가기 →", app_handoffs_path, class: "hover:underline" %>
    </div>
  </div>
  <div class="rounded-lg bg-indigo-50 border-2 border-indigo-200 p-4">
    <div class="text-3xl font-bold text-indigo-700"><%= @today[:automations_failed] %></div>
    <div class="text-sm text-indigo-800 mt-1 font-medium">자동화 실패/주의</div>
    <div class="text-xs text-indigo-600 mt-0.5">
      <%= link_to "자동화 설정 →", app_automation_rules_path, class: "hover:underline" %>
    </div>
  </div>
</div>

<%# ── ② 셋업 준비도 ── %>
<% if @setup_readiness %>
  <% sr = @setup_readiness %>
  <div id="setup" class="mb-6 rounded-lg border-2 <%= sr[:ready] ? 'border-emerald-300 bg-emerald-50' : 'border-amber-300 bg-amber-50' %> p-5">
    <div class="flex items-center justify-between mb-3">
      <div>
        <h2 class="font-bold text-lg <%= sr[:ready] ? 'text-emerald-900' : 'text-amber-900' %>">
          <%= sr[:ready] ? '✅' : '🛠️' %> 셋업 준비도
        </h2>
        <p class="text-xs <%= sr[:ready] ? 'text-emerald-700' : 'text-amber-700' %> mt-0.5">
          운영팀과 함께 정한 항목이 모두 채워지면, 정식 운영으로 전환할 수 있습니다.
        </p>
      </div>
      <div class="text-right">
        <div class="text-3xl font-bold <%= sr[:ready] ? 'text-emerald-700' : 'text-amber-700' %>"><%= sr[:percent] %>%</div>
        <div class="text-xs <%= sr[:ready] ? 'text-emerald-600' : 'text-amber-600' %>"><%= sr[:passed] %>/<%= sr[:total] %> 항목 통과</div>
      </div>
    </div>

    <div class="w-full bg-white/70 rounded-full h-3 overflow-hidden mb-4">
      <div class="h-3 <%= sr[:ready] ? 'bg-emerald-500' : 'bg-amber-500' %> transition-all" style="width: <%= sr[:percent] %>%"></div>
    </div>

    <ul class="space-y-1.5 text-sm">
      <% sr[:checks].each do |label, ok| %>
        <li class="flex items-center gap-2">
          <span class="<%= ok ? 'text-emerald-600' : 'text-rose-500' %>"><%= ok ? '✓' : '✕' %></span>
          <span class="<%= ok ? 'text-slate-700' : 'text-slate-900 font-medium' %>"><%= label %></span>
        </li>
      <% end %>
    </ul>

    <% if sr[:ready] %>
      <div class="mt-4 pt-3 border-t border-emerald-200 text-sm text-emerald-900">
        <strong>정식 운영 전환 가능</strong> — 운영팀과 일정을 협의해 주세요.
      </div>
    <% else %>
      <div class="mt-4 pt-3 border-t border-amber-200 text-sm text-amber-900">
        <strong>다음 단계:</strong> 위 ✕ 항목을 운영팀과 함께 정리하면 정식 운영으로 전환할 수 있습니다.
      </div>
    <% end %>
  </div>
<% end %>

<%# ── ③ 확인 영역 (Handoff + 콘텐츠 검수 통합) — P0-6 흡수 대상이지만 시각은 미리 정리 ── %>
<% if @handoffs_pending.any? || @pending_contents.any? %>
  <div class="mb-6 rounded-lg border-2 border-amber-300 bg-amber-50 p-4">
    <div class="flex items-center justify-between mb-3">
      <h2 class="font-bold text-amber-900 flex items-center gap-2">
        ⚠️ 확인이 필요한 항목 <span class="text-sm font-normal text-amber-700">(<%= @handoffs_pending.count + @pending_contents.count %>건)</span>
      </h2>
      <%= link_to "모두 보기 →", app_handoffs_path, class: "text-sm text-amber-800 hover:underline" %>
    </div>

    <% if @handoffs_pending.any? %>
      <div class="mb-3">
        <p class="text-xs font-semibold text-amber-900 mb-2">📞 사람 인계 (<%= @handoffs_pending.count %>건)</p>
        <ul class="space-y-2">
          <% @handoffs_pending.first(3).each do |h| %>
            <li class="bg-white rounded p-3 text-sm border border-amber-200">
              <div class="flex items-center justify-between">
                <div>
                  <span class="inline-block px-2 py-0.5 rounded bg-rose-100 text-rose-700 text-xs font-medium mr-2"><%= h.reason %></span>
                  <%= h.summary %>
                </div>
                <%= link_to "확인", app_handoff_path(h), class: "text-amber-800 hover:underline text-sm whitespace-nowrap" %>
              </div>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <% if @pending_contents.any? %>
      <div>
        <p class="text-xs font-semibold text-amber-900 mb-2">📝 검수 대기 중인 글 (<%= @pending_contents.count %>건)</p>
        <ul class="space-y-2">
          <% @pending_contents.first(3).each do |c| %>
            <li class="bg-white rounded p-3 text-sm border border-amber-200">
              <div class="flex items-center justify-between">
                <span class="text-slate-900 truncate flex-1"><%= c.title %></span>
                <%= link_to "검수", edit_app_content_item_path(c), class: "text-amber-800 hover:underline text-sm whitespace-nowrap" %>
              </div>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="mb-6 rounded-lg border border-emerald-200 bg-emerald-50 p-3 text-sm text-emerald-800">
    ✅ 확인이 필요한 항목이 없습니다. 모두 처리되었어요.
  </div>
<% end %>

<%# ── ④ 이번 주 흐름 + 오늘 보고 ── %>
<div class="grid grid-cols-1 lg:grid-cols-3 gap-4 mb-6">
  <div class="rounded-lg border border-slate-200 bg-white p-4">
    <h3 class="font-semibold text-slate-900 mb-3">📅 이번 주 흐름</h3>
    <ul class="space-y-2 text-sm">
      <li class="flex justify-between border-l-2 border-emerald-400 pl-3 py-1">
        <span>작성한 글</span>
        <span class="font-bold text-slate-900"><%= @week[:contents_generated] %>건</span>
      </li>
      <li class="flex justify-between border-l-2 border-sky-400 pl-3 py-1">
        <span>발행한 글</span>
        <span class="font-bold text-slate-900"><%= @week[:contents_published] %>건</span>
      </li>
      <li class="flex justify-between border-l-2 border-indigo-400 pl-3 py-1">
        <span>응대한 문의</span>
        <span class="font-bold text-slate-900"><%= @week[:conversations_total] %>건</span>
      </li>
      <li class="flex justify-between border-l-2 border-purple-400 pl-3 py-1">
        <span>처리한 인계</span>
        <span class="font-bold text-slate-900"><%= @week[:handoffs_resolved] %>건</span>
      </li>
    </ul>
  </div>

  <div class="rounded-lg border border-slate-200 bg-white p-4">
    <div class="flex items-center justify-between mb-3">
      <h3 class="font-semibold text-slate-900">📋 오늘 일일 보고</h3>
      <%= link_to "전체 →", app_delivery_logs_path, class: "text-xs text-emerald-700 hover:underline" %>
    </div>
    <% if @daily_report %>
      <div class="text-sm space-y-1">
        <p class="font-medium text-slate-900"><%= @daily_report.subject %></p>
        <p class="text-xs text-slate-600"><%= @daily_report.body_excerpt %></p>
        <p class="text-xs text-slate-400 mt-1">수신 <%= @daily_report.recipient_count %>명 · <%= @daily_report.created_at.strftime("%H:%M") %></p>
      </div>
    <% else %>
      <p class="text-sm text-slate-400">아직 오늘 일일 보고가 없습니다. (저녁 21:00 생성 예정)</p>
    <% end %>
  </div>

  <div class="rounded-lg border border-slate-200 bg-white p-4">
    <div class="flex items-center justify-between mb-3">
      <h3 class="font-semibold text-slate-900">⏰ 다음 자동화 루틴</h3>
      <%= link_to "루틴 설정 →", app_automation_rules_path, class: "text-xs text-emerald-700 hover:underline" %>
    </div>
    <% if @upcoming_routines.any? %>
      <ul class="space-y-2 text-sm">
        <% @upcoming_routines.each do |r| %>
          <li class="flex items-center justify-between border-l-2 border-indigo-400 pl-3 py-1">
            <span class="truncate flex-1"><%= r.automation_rule&.name || "루틴 ##{r.id}" %></span>
            <span class="text-xs text-slate-500 whitespace-nowrap ml-2"><%= r.next_run_at&.strftime("%m/%d %H:%M") %></span>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-sm text-slate-400">예정된 자동화 루틴이 없습니다.</p>
    <% end %>
  </div>
</div>

<%# ── ⑤ 공지사항 ── %>
<% if @announcements.any? %>
  <div class="mb-6 rounded-lg border border-slate-200 bg-white p-5">
    <h2 class="font-bold text-lg mb-3">📢 공지사항</h2>
    <ul class="divide-y divide-slate-100">
      <% @announcements.each do |a| %>
        <li class="py-3">
          <div class="flex items-center justify-between mb-1">
            <div class="flex items-center gap-2">
              <span class="inline-block px-2 py-0.5 rounded text-xs font-medium <%= a.kind == 'critical' ? 'bg-rose-100 text-rose-700' : a.kind == 'warning' ? 'bg-amber-100 text-amber-700' : 'bg-slate-100 text-slate-700' %>">
                <%= case a.kind
                    when 'critical' then '긴급'
                    when 'warning' then '안내'
                    when 'info' then '소식'
                    else a.kind
                    end %>
              </span>
              <span class="font-medium text-sm text-slate-900"><%= a.title %></span>
            </div>
            <span class="text-xs text-slate-500"><%= a.published_at&.strftime("%Y-%m-%d") %></span>
          </div>
          <p class="text-xs text-slate-600 ml-1"><%= a.body.to_s.truncate(140) %></p>
        </li>
      <% end %>
    </ul>
  </div>
<% end %>

<%# ── ⑥ 상세 운영 지표 (접힘) ── %>
<details class="rounded-lg border border-slate-200 bg-white">
  <summary class="px-5 py-3 cursor-pointer text-sm font-medium text-slate-700 hover:bg-slate-50">📊 상세 운영 지표 (최근 <%= @days %>일)</summary>
  <div class="p-5 border-t border-slate-100">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-4">
      <%= render "kpi", label: "콘텐츠 생성",    value: @metrics.content_total,         sub: "발행 #{@metrics.content_published}건" %>
      <%= render "kpi", label: "발행 성공률",    value: "#{@metrics.publish_success_rate}%", sub: "#{@metrics.publish_succeeded}/#{@metrics.publish_attempts}건" %>
      <%= render "kpi", label: "응답률",         value: "#{@metrics.response_rate}%",    sub: "#{@metrics.conversations_responded}/#{@metrics.conversations_total}건" %>
      <%= render "kpi", label: "자동화 성공률",  value: "#{@metrics.automation_success_rate}%", sub: "#{@metrics.automations_succeeded}/#{@metrics.automations_run}건" %>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <%= render "kpi", label: "활성 채널",        value: @metrics.active_channels,        sub: @metrics.channels_by_kind.map { |k, v| "#{k}:#{v}" }.join(" · ").presence || "없음" %>
      <%= render "kpi", label: "검수 대기",        value: @metrics.content_pending,        sub: "예약 #{@metrics.content_scheduled}건" %>
      <%= render "kpi", label: "사람 인계 대기",   value: @metrics.handoffs_open,          sub: "누적 #{@metrics.handoffs_total}건" %>
      <%= render "kpi", label: "문의 (글로벌)",    value: @metrics.inquiries_total,        sub: "최근 #{@days}일" %>
    </div>
  </div>
</details>