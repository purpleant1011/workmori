<% content_for(:title, "AI 직원 신규 — Sohee Project") %>
<header class="mb-6">
  <h1 class="text-2xl font-bold">AI 직원 직접 만들기</h1>
  <p class="mt-1 text-sm text-slate-500">처음부터 모든 설정을 직접 정의합니다.</p>
</header>

<%= form_with model: @employee, url: app_ai_employees_path, method: :post, local: true, class: "space-y-6 max-w-3xl" do |f| %>
  <% if @employee.errors.any? %>
    <div class="rounded-md border border-rose-300 bg-rose-50 p-3 text-sm text-rose-700">
      <%= @employee.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div class="rounded-md border border-slate-200 bg-white p-6">
    <h2 class="font-semibold mb-4">기본 정보</h2>
    <div class="grid grid-cols-2 gap-3">
      <div>
        <%= f.label :name, "이름 *", class: "block text-sm font-medium text-slate-700" %>
        <%= f.text_field :name, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm", placeholder: "예: 카페 안내 담당" %>
      </div>
      <div>
        <%= f.label :role_label, "역할 라벨", class: "block text-sm font-medium text-slate-700" %>
        <%= f.text_field :role_label, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm", placeholder: "예: 매장 안내 / 컨시어지 / 상담" %>
      </div>
      <div>
        <%= f.label :persona_preset, "프리셋 키 (선택)", class: "block text-sm font-medium text-slate-700" %>
        <%= f.select :persona_preset, [["없음", nil]] + AiEmployee::PERSONA_PRESETS.keys.map { |k| [k, k] }, {}, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
      </div>
      <div>
        <%= f.label :industry_expertise, "산업 전문성", class: "block text-sm font-medium text-slate-700" %>
        <%= f.text_field :industry_expertise, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm", placeholder: "예: 카페/음료, 미용/뷰티" %>
      </div>
    </div>
  </div>

  <div class="rounded-md border border-slate-200 bg-white p-6">
    <h2 class="font-semibold mb-4">페르소나 & 말투</h2>
    <div class="grid grid-cols-2 gap-3">
      <div>
        <%= f.label :tone, "톤", class: "block text-sm font-medium text-slate-700" %>
        <%= f.select :tone, AiEmployee::TONE_LABELS.to_a.map(&:reverse), {}, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
      </div>
      <div>
        <%= f.label :honorific, "존칭", class: "block text-sm font-medium text-slate-700" %>
        <%= f.select :honorific, AiEmployee::HONORIFIC_LABELS.to_a.map(&:reverse), {}, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
      </div>
      <div>
        <%= f.label :sentence_length, "문장 길이", class: "block text-sm font-medium text-slate-700" %>
        <%= f.select :sentence_length, AiEmployee::SENTENCE_LENGTH_LABELS.to_a.map(&:reverse), {}, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
      </div>
      <div>
        <%= f.label :preferred_locale, "기본 언어", class: "block text-sm font-medium text-slate-700" %>
        <%= f.select :preferred_locale, [["한국어", "ko"], ["English", "en"], ["日本語", "ja"]], {}, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
      </div>
    </div>
    <div class="mt-4 space-y-3">
      <div>
        <%= f.label :friendliness, "친절함 (0~100)", class: "block text-sm font-medium text-slate-700" %>
        <%= f.range_field :friendliness, in: 0..100, class: "w-full" %>
        <span class="text-xs text-slate-500">현재: <%= @employee.friendliness || 50 %></span>
      </div>
      <div>
        <%= f.label :expertise_level, "전문성 (0~100)", class: "block text-sm font-medium text-slate-700" %>
        <%= f.range_field :expertise_level, in: 0..100, class: "w-full" %>
        <span class="text-xs text-slate-500">현재: <%= @employee.expertise_level || 50 %></span>
      </div>
      <div>
        <%= f.label :proactiveness, "능동성 (0~100, 자동 행동 빈도)", class: "block text-sm font-medium text-slate-700" %>
        <%= f.range_field :proactiveness, in: 0..100, class: "w-full" %>
        <span class="text-xs text-slate-500">현재: <%= @employee.proactiveness || 50 %></span>
      </div>
    </div>
  </div>

  <div class="rounded-md border border-slate-200 bg-white p-6">
    <h2 class="font-semibold mb-4">자연어 지시 (가장 중요)</h2>
    <p class="text-xs text-slate-500 mb-2">AI 직원에게 자연어로 업무 방식을 설명합니다. 자세할수록 좋습니다.</p>
    <%= f.text_area :natural_language_instructions, rows: 6, class: "block w-full rounded-md border border-slate-300 px-3 py-2 text-sm font-mono", placeholder: "예: 손님에게 항상 따뜻하고 정중하게 응대합니다. 메뉴 추천은 사장님이 가장 좋아하시는 시즌 음료를 먼저 추천합니다." %>
  </div>

  <div class="rounded-md border border-slate-200 bg-white p-6">
    <h2 class="font-semibold mb-4">어휘 / 금지어</h2>
    <div class="space-y-3">
      <div>
        <%= f.label :vocabulary_phrases_json, "추천 어휘 (쉼표 구분)", class: "block text-sm font-medium text-slate-700" %>
        <%= f.text_field :vocabulary_phrases_json, value: Array(@employee.vocabulary_phrases_json).join(", "), class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm", placeholder: "오늘의 추천, 시즌 한정, 사장님 직접 로스팅" %>
      </div>
      <div>
        <%= f.label :forbidden_phrases_json, "금지어 (쉼표 구분)", class: "block text-sm font-medium text-slate-700" %>
        <%= f.text_field :forbidden_phrases_json, value: Array(@employee.forbidden_phrases_json).join(", "), class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm", placeholder: "저렴한, 무료, 대리점" %>
      </div>
    </div>
  </div>

  <div class="rounded-md border border-slate-200 bg-white p-6">
    <h2 class="font-semibold mb-4">응대 가능 / 사람 인계</h2>
    <div class="space-y-3">
      <div>
        <%= f.label :can_answer_topics_json, "응대 가능한 주제 (쉼표 구분)", class: "block text-sm font-medium text-slate-700" %>
        <%= f.text_field :can_answer_topics_json, value: Array(@employee.can_answer_topics_json).join(", "), class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm", placeholder: "메뉴, 가격, 영업시간, 위치, 예약" %>
      </div>
      <div>
        <%= f.label :must_handoff_topics_json, "사람에게 인계할 주제 (쉼표 구분)", class: "block text-sm font-medium text-slate-700" %>
        <%= f.text_field :must_handoff_topics_json, value: Array(@employee.must_handoff_topics_json).join(", "), class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm", placeholder: "환불, 민원, 컴플레인, 가격협상" %>
      </div>
    </div>
  </div>

  <div class="flex gap-2">
    <%= f.submit "생성", class: "inline-flex items-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700" %>
    <%= link_to "취소", app_ai_employees_path, class: "inline-flex items-center rounded-md border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50" %>
  </div>
<% end %>