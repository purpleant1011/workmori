<h1 class="text-xl font-bold mb-4">회사 정보</h1>
<% if @business_profile.nil? || @business_profile.legal_name.blank? %>
  <p class="text-slate-500">아직 회사 정보가 등록되지 않았습니다. <a class="underline text-emerald-700" href="<%= app_edit_business_profile_path %>">등록하러 가기</a></p>
<% else %>
  <dl class="grid grid-cols-2 gap-y-2 text-sm bg-white p-4 rounded border">
    <dt class="font-semibold">회사명</dt><dd><%= @business_profile.legal_name %></dd>
    <dt class="font-semibold">업종</dt><dd><%= @business_profile.industry_code %> / <%= @business_profile.industry_subcategory %></dd>
    <dt class="font-semibold">대표자</dt><dd><%= @business_profile.owner_name %></dd>
    <dt class="font-semibold">연락처</dt><dd><%= @business_profile.phone %></dd>
    <dt class="font-semibold">이메일</dt><dd><%= @business_profile.public_email %></dd>
    <dt class="font-semibold">주소</dt><dd><%= @business_profile.address %> (<%= @business_profile.region_label %>)</dd>
    <dt class="font-semibold">소개</dt><dd class="col-span-2"><%= @business_profile.brand_intro %></dd>
  </dl>
  <a class="mt-3 inline-block text-emerald-700 underline" href="<%= app_edit_business_profile_path %>">편집</a>
<% end %>
