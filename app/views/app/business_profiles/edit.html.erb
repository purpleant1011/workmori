<% content_for :title, "사업장 정보 편집" %>

<div class="flex items-center justify-between mb-4">
  <div>
    <h1 class="text-2xl font-bold">🏪 사업장 정보 편집</h1>
    <p class="text-xs text-slate-500 mt-0.5">소희가 학습할 사업장 정보입니다. 정확하게 입력할수록 소희 응답이 정확해집니다.</p>
  </div>
  <a href="/app/business_profile" class="px-4 py-2 bg-slate-100 text-slate-700 rounded text-sm font-medium hover:bg-slate-200">← 돌아가기</a>
</div>

<%= form_with model: @business_profile, url: "/app/business_profile", method: :patch, local: true, scope: :business_profile, class: "space-y-6" do |f| %>
  <% if @business_profile.errors.any? %>
    <div class="rounded-md bg-rose-50 border border-rose-200 p-4 text-sm text-rose-700">
      <p class="font-semibold mb-1">아래 정보를 확인해 주세요:</p>
      <ul class="list-disc pl-5">
        <% @business_profile.errors.full_messages.each do |m| %><li><%= m %></li><% end %>
      </ul>
    </div>
  <% end %>

  <%# ── 기본 정보 ── %>
  <section class="rounded-lg border border-slate-200 bg-white p-5">
    <h2 class="font-bold text-lg mb-3">📋 기본 정보</h2>
    <p class="text-xs text-slate-500 mb-4">사업자등록증에 적힌 정확한 상호명을 입력해 주세요. 잘못된 정보는 자동 검수에서 걸립니다.</p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <%= f.label :legal_name, "상호 (필수)", class: "block text-sm font-medium mb-1" %>
        <%= f.text_field :legal_name, class: "w-full border border-slate-300 rounded-md px-3 py-2 text-sm", placeholder: "예: 카페 소희" %>
      </div>
      <div>
        <%= f.label :trade_name, "브랜드명 / 사장님 호칭", class: "block text-sm font-medium mb-1" %>
        <%= f.text_field :trade_name, class: "w-full border border-slate-300 rounded-md px-3 py-2 text-sm", placeholder: "예: 소희네 카페" %>
      </div>
      <div>
        <%= f.label :industry_code, "업종 (필수)", class: "block text-sm font-medium mb-1" %>
        <%= f.select :industry_code, BusinessProfile.industry_code_labels, { include_blank: "선택…" }, class: "w-full border border-slate-300 rounded-md px-3 py-2 text-sm" %>
      </div>
      <div>
        <%= f.label :industry_subcategory, "업종 세부 분류", class: "block text-sm font-medium mb-1" %>
        <%= f.text_field :industry_subcategory, class: "w-full border border-slate-300 rounded-md px-3 py-2 text-sm", placeholder: "예: 스페셜티 커피, 애견 동반" %>
      </div>
      <div>
        <%= f.label :owner_name, "대표자명 (필수)", class: "block text-sm font-medium mb-1" %>
        <%= f.text_field :owner_name, class: "w-full border border-slate-300 rounded-md px-3 py-2 text-sm" %>
      </div>
      <div>
        <%= f.label :phone, "대표 연락처 (필수)", class: "block text-sm font-medium mb-1" %>
        <%= f.text_field :phone, class: "w-full border border-slate-300 rounded-md px-3 py-2 text-sm", placeholder: "010-1234-5678" %>
      </div>
      <div>
        <%= f.label :public_email, "공개용 이메일", class: "block text-sm font-medium mb-1" %>
        <%= f.email_field :public_email, class: "w-full border border-slate-300 rounded-md px-3 py-2 text-sm", placeholder: "선택 입력" %>
      </div>
      <div>
        <%= f.label :region_label, "활동 지역 (필수)", class: "block text-sm font-medium mb-1" %>
        <%= f.text_field :region_label, class: "w-full border border-slate-300 rounded-md px-3 py-2 text-sm", placeholder: "예: 서울 성수동" %>
      </div>
      <div class="md:col-span-2">
        <%= f.label :address, "주소", class: "block text-sm font-medium mb-1" %>
        <%= f.text_field :address, class: "w-full border border-slate-300 rounded-md px-3 py-2 text-sm", placeholder: "선택 입력" %>
      </div>
    </div>
  </section>

  <%# ── 브랜드 소개 ── %>
  <section class="rounded-lg border border-slate-200 bg-white p-5">
    <h2 class="font-bold text-lg mb-3">🎯 브랜드 소개</h2>
    <p class="text-xs text-slate-500 mb-4">소희가 신규 고객에게 우리 매장을 한 줄로 설명할 때 사용합니다.</p>
    <div class="space-y-4">
      <div>
        <%= f.label :brand_intro, "한 줄 소개 (필수)", class: "block text-sm font-medium mb-1" %>
        <%= f.text_area :brand_intro, rows: 2, class: "w-full border border-slate-300 rounded-md px-3 py-2 text-sm", placeholder: "예: 성수동의 작은 디저트 카페. 당일 만든 케이크와 핸드드립 커피." %>
      </div>
      <div>
        <%= f.label :target_audience, "주 고객층", class: "block text-sm font-medium mb-1" %>
        <%= f.text_area :target_audience, rows: 2, class: "w-full border border-slate-300 rounded-md px-3 py-2 text-sm", placeholder: "예: 20-30대 직장인, 동네 주민, 디저트를 좋아하는 손님" %>
      </div>
      <div>
        <%= f.label :differentiators, "차별화 포인트", class: "block text-sm font-medium mb-1" %>
        <%= f.text_area :differentiators, rows: 2, class: "w-full border border-slate-300 rounded-md px-3 py-2 text-sm", placeholder: "예: 매일 직접 굽는 크루아상, 비건 옵션 5종, 반려동물 동반 가능" %>
      </div>
    </div>
  </section>

  <%# ── 영업시간 ── %>
  <section class="rounded-lg border border-slate-200 bg-white p-5">
    <h2 class="font-bold text-lg mb-3">🕒 영업시간</h2>
    <p class="text-xs text-slate-500 mb-4">요일별로 영업시간을 입력해 주세요. 비워두면 "영업시간 문의 필요"로 안내합니다.</p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
      <% %w[mon tue wed thu fri sat sun].each do |day| %>
        <% day_label = { "mon" => "월요일", "tue" => "화요일", "wed" => "수요일", "thu" => "목요일", "fri" => "금요일", "sat" => "토요일", "sun" => "일요일" }[day] %>
        <div class="flex items-center gap-2 border border-slate-100 rounded p-2">
          <span class="font-medium text-sm w-16"><%= day_label %></span>
          <input type="time" name="business_profile[business_hours_json][<%= day %>][open]" value="<%= (@business_profile.business_hours_json || {})[day]&.first %>" class="border border-slate-300 rounded px-2 py-1 text-sm">
          <span class="text-slate-500">~</span>
          <input type="time" name="business_profile[business_hours_json][<%= day %>][close]" value="<%= (@business_profile.business_hours_json || {})[day]&.last %>" class="border border-slate-300 rounded px-2 py-1 text-sm">
        </div>
      <% end %>
    </div>
    <div class="mt-3">
      <%= f.label :holidays_json, "정기 휴무일", class: "block text-sm font-medium mb-1" %>
      <%= f.text_field :holidays_json, value: Array(@business_profile.holidays_json).join(", "), class: "w-full border border-slate-300 rounded-md px-3 py-2 text-sm", placeholder: "예: 매주 월요일, 설·추석 연휴" %>
      <p class="text-xs text-slate-500 mt-1">콤마(,)로 구분해 입력해 주세요.</p>
    </div>
  </section>

  <%# ── 인계 규칙 ── %>
  <section class="rounded-lg border-2 border-rose-200 bg-rose-50 p-5">
    <h2 class="font-bold text-rose-900 mb-3">⚠️ 원장님께 인계해야 하는 주제</h2>
    <p class="text-xs text-rose-700 mb-3">이 주제에 대한 문의가 들어오면 소희는 답하지 않고 원장님께 연결합니다.</p>
    <%= f.text_area :escalation_rules_json, value: Array(@business_profile.escalation_rules_json).join("\n"), rows: 4, class: "w-full border border-rose-200 rounded-md px-3 py-2 text-sm bg-white", placeholder: "예: 환불 요청\n민원·컴플레인\n단체 예약 10인 이상\n특가 협상" %>
    <p class="text-xs text-rose-600 mt-1">한 줄에 하나씩 입력해 주세요.</p>
  </section>

  <%# ── 운영팀 안내 ── %>
  <div class="rounded-lg border border-sky-200 bg-sky-50 p-4 text-sm text-sky-900">
    <p>💡 <strong>도움이 필요하신가요?</strong> 사업장 정보 입력은 운영팀이 함께 도와드립니다. 어려운 부분이 있으시면 상단의 "도움 요청" 메뉴로 알려 주세요.</p>
  </div>

  <div class="flex justify-end gap-2">
    <a href="/app/business_profile" class="px-4 py-2 bg-slate-100 text-slate-700 rounded-md text-sm font-medium">취소</a>
    <%= f.submit "저장", class: "px-4 py-2 bg-emerald-600 text-white rounded-md text-sm font-medium hover:bg-emerald-700 cursor-pointer" %>
  </div>
<% end %>