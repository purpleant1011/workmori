<% content_for :title, "채널 추가" %>
<div class="max-w-xl mx-auto p-6">
  <h1 class="text-2xl font-bold mb-5">새 채널 추가</h1>
  <%= form_with model: @channel, url: "/app/channels", local: true, class: "space-y-4" do |f| %>
    <div>
      <%= f.label :kind, "채널 종류", class: "block text-sm font-medium mb-1" %>
      <%= f.select :kind, ChannelConnection::KINDS.map { |k| [k.humanize, k] }, { prompt: "선택…" }, class: "w-full border border-slate-300 rounded-md p-2" %>
    </div>
    <div>
      <%= f.label :handle, "계정/핸들", class: "block text-sm font-medium mb-1" %>
      <%= f.text_field :handle, class: "w-full border border-slate-300 rounded-md p-2", placeholder: "예: myshop_official" %>
    </div>
    <div>
      <%= f.label :external_id, "채널 계정 번호 (선택)", class: "block text-sm font-medium mb-1" %>
      <%= f.text_field :external_id, class: "w-full border border-slate-300 rounded-md p-2" %>
      <p class="text-xs text-slate-500 mt-1">채널에서 발행된 글을 추적할 때 사용하는 번호입니다. 운영팀이 발급해 드릴 수도 있어요.</p>
    </div>
    <div class="flex gap-2">
      <%= f.submit "추가", class: "px-4 py-2 bg-emerald-600 text-white rounded-md" %>
      <%= link_to "취소", app_channels_path, class: "px-4 py-2 bg-slate-200 text-slate-700 rounded-md" %>
    </div>
  <% end %>
</div>