<% content_for(:title, "지식 소스 수정 — Sohee Project") %>
<header class="mb-6">
  <h1 class="text-2xl font-bold">📚 지식 소스 수정</h1>
</header>

<%= form_with model: @source, url: "/app/knowledge/sources/#{@source.id}", method: :patch, local: true, multipart: true, class: "space-y-6 max-w-3xl" do |f| %>
  <% if @source.errors.any? %>
    <div class="rounded-md border border-rose-300 bg-rose-50 p-3 text-sm text-rose-700">
      <%= @source.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div class="rounded-md border border-slate-200 bg-white p-6 space-y-4">
    <h2 class="font-semibold mb-4">기본 정보</h2>
    <div>
      <%= f.label :title, "제목 *", class: "block text-sm font-medium text-slate-700" %>
      <%= f.text_field :title, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div class="grid grid-cols-2 gap-3">
      <div>
        <%= f.label :ai_employee_id, "전담 AI 직원", class: "block text-sm font-medium text-slate-700" %>
        <%= f.select :ai_employee_id, [["공통", nil]] + @ai_employees.map { |e| [e.name, e.id] }, {}, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
      </div>
      <div>
        <%= f.label :language, "언어", class: "block text-sm font-medium text-slate-700" %>
        <%= f.select :language, [["한국어", "ko"], ["English", "en"], ["日本語", "ja"]], {}, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
      </div>
    </div>
    <div>
      <%= f.label :tags, "태그 (쉼표 구분)", class: "block text-sm font-medium text-slate-700" %>
      <%= f.text_field :tags, value: Array(@source.tags_json).join(", "), class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
  </div>

  <div class="rounded-md border border-slate-200 bg-white p-6 space-y-4">
    <h2 class="font-semibold mb-4">자료 본문 / 파일</h2>
    <div>
      <%= f.label :content, "직접 입력", class: "block text-sm font-medium text-slate-700" %>
      <%= f.text_area :content, rows: 8, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm font-mono" %>
    </div>
    <% if @source.file.attached? %>
      <div class="rounded-md border border-slate-200 bg-slate-50 p-3 text-sm">
        현재 첨부: <%= @source.file.filename %> (<%= number_to_human_size(@source.file.byte_size) %>)
      </div>
    <% end %>
    <div>
      <label class="block text-sm font-medium text-slate-700">파일 교체 (선택)</label>
      <input type="file" name="knowledge_source[file]" accept=".pdf,.docx,.txt,.md,.csv" class="mt-1 block w-full text-sm">
    </div>
    <div>
      <%= f.label :url, "웹페이지 URL", class: "block text-sm font-medium text-slate-700" %>
      <%= f.url_field :url, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
  </div>

  <div class="flex gap-2">
    <%= f.submit "저장", class: "inline-flex items-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700" %>
    <%= link_to "취소", "/app/knowledge/sources/#{@source.id}", class: "inline-flex items-center rounded-md border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50" %>
  </div>
<% end %>