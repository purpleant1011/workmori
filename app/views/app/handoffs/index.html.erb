<% content_for :title, "원장님 확인 필요 · #{@current_account.name}" %>

<div class="flex items-center justify-between mb-4">
  <div>
    <h1 class="text-2xl font-bold">⚠️ 원장님 확인 필요</h1>
    <p class="text-xs text-slate-500 mt-0.5">소희가 처리할 수 없어 원장님의 판단이 필요한 항목만 모았습니다.</p>
  </div>
</div>

<%# ── 진행 중 ── %>
<div class="rounded-lg border border-amber-300 bg-amber-50 p-4 mb-4">
  <h2 class="font-bold text-amber-900 mb-3">🔴 지금 확인 필요 (<%= @handoffs.where(state: "open").count %>건)</h2>
  <% open_h = @handoffs.where(state: "open") %>
  <% if open_h.any? %>
    <ul class="space-y-2">
      <% open_h.each do |h| %>
        <li class="bg-white rounded p-3 text-sm border border-amber-200">
          <div class="flex items-start justify-between gap-3">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1">
                <span class="inline-block px-2 py-0.5 rounded bg-rose-100 text-rose-700 text-xs font-medium"><%= h.reason %></span>
                <span class="text-xs text-slate-500"><%= h.channel %></span>
                <span class="text-xs text-slate-400"><%= time_ago_in_words(h.created_at) %> 전</span>
              </div>
              <p class="text-slate-900"><%= h.summary %></p>
            </div>
            <%= link_to "확인 →", app_handoff_path(h), class: "text-sm whitespace-nowrap px-3 py-1.5 bg-amber-600 text-white rounded hover:bg-amber-700" %>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-sm text-emerald-700">✅ 처리할 항목이 없습니다.</p>
  <% end %>
</div>

<%# ── 처리 완료 ── %>
<div class="rounded-lg border border-slate-200 bg-white p-4">
  <h2 class="font-bold text-slate-700 mb-3">✅ 처리 완료</h2>
  <% resolved = @handoffs.where(state: "resolved").limit(20) %>
  <% if resolved.any? %>
    <ul class="divide-y divide-slate-100">
      <% resolved.each do |h| %>
        <li class="py-2 text-sm">
          <div class="flex items-center justify-between">
            <span class="text-slate-700"><%= h.summary %></span>
            <span class="text-xs text-slate-500"><%= h.resolved_at&.strftime("%m/%d %H:%M") %></span>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-sm text-slate-400">처리 완료된 항목이 없습니다.</p>
  <% end %>
</div>