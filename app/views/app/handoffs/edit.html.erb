<% content_for :title, "핸드오프 수정" %>
<div class="mx-auto max-w-3xl space-y-6">
  <header class="flex items-center justify-between">
    <h1 class="text-2xl font-bold tracking-tight text-slate-900">핸드오프 수정</h1>
    <%= link_to "← 상세", app_handoff_path(@handoff), class: "text-sm text-indigo-600 hover:underline" %>
  </header>
  <%= form_with model: @handoff, url: app_handoff_path(@handoff), method: :patch, local: true, class: "space-y-4 rounded-lg border border-slate-200 bg-white p-6 shadow-sm" do |f| %>
    <% if @handoff.errors.any? %>
      <div class="rounded-md bg-rose-50 p-4 text-sm text-rose-700">
        <ul class="list-disc pl-5">
          <% @handoff.errors.full_messages.each do |m| %><li><%= m %></li><% end %>
        </ul>
      </div>
    <% end %>
    <div>
      <label class="block text-sm font-medium text-slate-700">사유</label>
      <%= f.text_field :reason, class: "mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-700">요약</label>
      <%= f.text_area :summary, rows: 4, class: "mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-700">처리 메모</label>
      <%= f.text_area :resolution_notes, rows: 4, class: "mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div>
      <label class="block text-sm font-medium text-slate-700">상태</label>
      <%= f.select :state, [["열림","open"],["확인됨","acknowledged"],["해결됨","resolved"],["보류","abandoned"]], {}, class: "mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div class="flex justify-end">
      <%= f.submit "저장", class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500" %>
    </div>
  <% end %>
</div>