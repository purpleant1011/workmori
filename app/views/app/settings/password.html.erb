<% content_for(:title, "비밀번호 변경 · Sohee Project") %>

<header class="mb-6">
  <h1 class="text-2xl font-bold text-slate-900">🔒 비밀번호 변경</h1>
  <p class="mt-1 text-sm text-slate-500">
    본인 확인을 위해 현재 비밀번호를 한 번 더 입력해야 합니다. 새 비밀번호는 8자 이상이어야 합니다.
  </p>
</header>

<% if flash[:alert] %>
  <div class="mb-4 rounded-md border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">
    <%= flash[:alert] %>
  </div>
<% end %>
<% if flash[:notice] %>
  <div class="mb-4 rounded-md border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700">
    <%= flash[:notice] %>
  </div>
<% end %>

<%= form_with url: app_settings_password_path, method: :patch, local: true, scope: :password_form, html: { class: "max-w-md space-y-4" } do |f| %>
  <div>
    <%= f.label :current_password, "현재 비밀번호", class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.password_field :current_password, required: true, autocomplete: "current-password",
        class: "block w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:ring-emerald-500" %>
  </div>

  <div>
    <%= f.label :new_password, "새 비밀번호 (8자 이상)", class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.password_field :new_password, required: true, autocomplete: "new-password", minlength: 8,
        class: "block w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:ring-emerald-500" %>
  </div>

  <div>
    <%= f.label :new_password_confirmation, "새 비밀번호 확인", class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.password_field :new_password_confirmation, required: true, autocomplete: "new-password", minlength: 8,
        class: "block w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:ring-emerald-500" %>
  </div>

  <div class="pt-2">
    <%= f.submit "비밀번호 변경",
        class: "inline-flex items-center rounded-md bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 cursor-pointer" %>
    <%= link_to "취소", app_settings_path, class: "ml-3 text-sm text-slate-500 hover:text-slate-700" %>
  </div>
<% end %>

<section class="mt-10 rounded-md border border-slate-200 bg-slate-50 px-5 py-4 text-sm text-slate-600 max-w-md">
  <p class="font-semibold text-slate-700 mb-1">안내</p>
  <ul class="list-disc list-inside space-y-1">
    <li>비밀번호 변경 후에도 다른 기기의 로그인 세션은 그대로 유지됩니다.</li>
    <li>변경 이력은 Hermes Audit(🛂 감사 로그)에 기록됩니다.</li>
    <li>비밀번호를 잊어버린 경우 운영팀에 초기화 요청을 보내 주세요.</li>
  </ul>
</section>