<% content_for(:title, "회원가입 — 14일 무료 체험 · Sohee Project") %>

<section class="mx-auto max-w-2xl px-6 py-12">
  <header class="mb-8 text-center">
    <h1 class="text-3xl font-bold text-slate-900">✨ 소희 작업실 회원가입</h1>
    <p class="mt-3 text-slate-600">
      사업장 운영에 필요한 정보를 입력해 주세요. 가입 즉시
      <strong class="text-emerald-700">14일 무료 체험</strong> 권한이 부여됩니다.
    </p>
    <p class="mt-2 text-sm text-slate-500">
      체험 기간 동안 정식 운영팀 검수와 별개로 모든 기능을 자유롭게 사용해 보실 수 있습니다.
    </p>
  </header>

  <% if flash[:alert] %>
    <div class="mb-6 rounded-md border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <%= form_with model: @signup, scope: :signup, url: signup_path, method: :post, local: true, html: { class: "space-y-5" } do |f| %>
    <% if @signup.errors.any? %>
      <div class="rounded-md border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">
        <p class="font-semibold mb-1">가입 정보를 다시 확인해 주세요.</p>
        <ul class="list-disc list-inside space-y-1">
          <% @signup.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :business_name, "사업장 (회사/매장) 이름", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.text_field :business_name, required: true, autofocus: true,
          class: "block w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:ring-emerald-500",
          placeholder: "예: 퍼플 안티에이징 스킨케어" %>
      <p class="mt-1 text-xs text-slate-500">사업장 슬러그(고유 URL) 자동 생성에 사용됩니다.</p>
    </div>

    <div>
      <%= f.label :industry_slug, "업종", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.select :industry_slug,
          IndustryTemplate.all.map { |t| [t.display_name, t.slug] },
          { include_blank: "선택 안 함 (나중에 설정)" },
          { class: "block w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:ring-emerald-500" } %>
    </div>

    <div>
      <%= f.label :owner_name, "대표자 (운영진) 이름", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.text_field :owner_name, required: true,
          class: "block w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:ring-emerald-500",
          placeholder: "예: 김소희" %>
    </div>

    <div>
      <%= f.label :email, "이메일 (로그인 ID)", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.email_field :email, required: true, autocomplete: "email",
          class: "block w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:ring-emerald-500",
          placeholder: "owner@business.com" %>
    </div>

    <div>
      <%= f.label :phone, "연락처 (선택)", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.telephone_field :phone, autocomplete: "tel",
          class: "block w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:ring-emerald-500",
          placeholder: "010-1234-5678" %>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <%= f.label :password, "비밀번호 (8자 이상)", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.password_field :password, required: true, autocomplete: "new-password",
            class: "block w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:ring-emerald-500" %>
      </div>
      <div>
        <%= f.label :password_confirmation, "비밀번호 확인", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.password_field :password_confirmation, required: true, autocomplete: "new-password",
            class: "block w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-emerald-500 focus:ring-emerald-500" %>
      </div>
    </div>

    <div class="space-y-2 pt-2">
      <label class="flex items-start gap-2 text-sm text-slate-700">
        <%= f.check_box :terms_accepted, required: true, class: "mt-0.5 h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" %>
        <span>
          <strong>(필수)</strong>
          <%= link_to "이용약관", "#", class: "text-emerald-700 underline" %> 및
          <%= link_to "개인정보 처리방침", "#", class: "text-emerald-700 underline" %>에 동의합니다.
        </span>
      </label>
      <label class="flex items-start gap-2 text-sm text-slate-700">
        <%= f.check_box :marketing_consent, class: "mt-0.5 h-4 w-4 rounded border-slate-300 text-emerald-600 focus:ring-emerald-500" %>
        <span>(선택) 운영 뉴스레터 및 마케팅 정보 수신에 동의합니다.</span>
      </label>
    </div>

    <div class="pt-4">
      <%= f.submit "14일 무료 체험 시작하기",
          class: "w-full inline-flex items-center justify-center rounded-md bg-emerald-600 px-6 py-3 text-base font-semibold text-white shadow-sm hover:bg-emerald-700 cursor-pointer disabled:opacity-50" %>
    </div>
  <% end %>

  <section class="mt-10 rounded-md border border-slate-200 bg-slate-50 px-5 py-4 text-sm text-slate-600">
    <p class="font-semibold text-slate-700 mb-2">체험 안내</p>
    <ul class="list-disc list-inside space-y-1">
      <li>가입 즉시 <strong>14일 무료 체험</strong>이 시작됩니다.</li>
      <li>체험 기간 동안 사업장 프로필 / AI 직원 / FAQ / 콘텐츠 검수 등 모든 기능을 자유롭게 사용하실 수 있습니다.</li>
      <li>정식 채널(인스타그램/스레드 등) 연결은 체험 기간 내 또는 종료 후 운영팀과 협의 후 진행됩니다.</li>
      <li>체험 종료 후에는 운영팀 미팅을 거쳐 정식 운영 플랜으로 전환됩니다.</li>
    </ul>
    <p class="mt-3 text-xs text-slate-500">
      이미 계정이 있으신가요?
      <%= link_to "로그인 페이지로", new_user_session_path, class: "text-emerald-700 underline" %>
    </p>
  </section>
</section>