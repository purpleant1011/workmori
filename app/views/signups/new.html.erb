<% content_for(:title, "회원가입 — WorkMori") %>

<section class="mx-auto max-w-xl px-6 py-16">
  <header class="mb-8 text-center">
    <h1 class="text-3xl font-bold text-slate-900">WorkMori 시작하기</h1>
    <p class="mt-2 text-sm text-slate-600">사업자 정보를 입력하면 1분 안에 데모 사업장이 생성됩니다. 운영자 검수 후 공식 채널이 열립니다.</p>
  </header>

  <% if @signup.errors.any? %>
    <div class="mb-6 rounded-md bg-rose-50 border border-rose-200 px-4 py-3 text-sm text-rose-800">
      <p class="font-semibold mb-1">가입 정보를 다시 확인해주세요.</p>
      <ul class="list-disc list-inside space-y-0.5">
        <% @signup.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: @signup, url: signups_path, method: :post, local: true, scope: :signup, class: "space-y-5" do |f| %>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div class="sm:col-span-2">
        <label class="block text-sm font-medium text-slate-700">상호 / 사업장 이름</label>
        <%= f.text_field :business_name,
              class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-indigo-500",
              required: true %>
      </div>

      <div>
        <label class="block text-sm font-medium text-slate-700">업종</label>
        <%= f.select :industry_slug,
              options_for_select([
                ["뷰티/스킨케어", "skincare"],
                ["카페/음료", "cafe"],
                ["소매/리테일", "shop"],
                ["기타", "general"]
              ], @signup.industry_slug),
              { include_blank: "선택 안 함" },
              class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-indigo-500" %>
      </div>

      <div>
        <label class="block text-sm font-medium text-slate-700">담당자 이름</label>
        <%= f.text_field :owner_name,
              class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-indigo-500",
              required: true %>
      </div>

      <div>
        <label class="block text-sm font-medium text-slate-700">이메일</label>
        <%= f.email_field :email,
              class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-indigo-500",
              required: true,
              autocomplete: "email" %>
      </div>

      <div>
        <label class="block text-sm font-medium text-slate-700">연락처</label>
        <%= f.telephone_field :phone,
              class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-indigo-500",
              autocomplete: "tel" %>
      </div>

      <div>
        <label class="block text-sm font-medium text-slate-700">비밀번호 (8자 이상)</label>
        <%= f.password_field :password,
              class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-indigo-500",
              required: true,
              autocomplete: "new-password" %>
      </div>

      <div>
        <label class="block text-sm font-medium text-slate-700">비밀번호 확인</label>
        <%= f.password_field :password_confirmation,
              class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-indigo-500 focus:ring-indigo-500",
              required: true,
              autocomplete: "new-password" %>
      </div>
    </div>

    <div class="space-y-2 pt-2">
      <label class="flex items-start gap-2 text-sm text-slate-700">
        <%= f.check_box :terms_accepted, required: true, class: "mt-0.5 rounded border-slate-300" %>
        <span><a href="<%= public_page_path('terms') %>" class="text-indigo-600 hover:underline">이용약관</a> 및 <a href="<%= public_page_path('privacy') %>" class="text-indigo-600 hover:underline">개인정보처리방침</a>에 동의합니다. <span class="text-rose-600">*</span></span>
      </label>
      <label class="flex items-start gap-2 text-sm text-slate-700">
        <%= f.check_box :marketing_consent, class: "mt-0.5 rounded border-slate-300" %>
        <span>마케팅 정보 수신에 동의합니다 (선택).</span>
      </label>
    </div>

    <div class="flex items-center justify-between text-sm">
      <a href="<%= new_user_session_path %>" class="text-indigo-600 hover:underline">이미 계정이 있으신가요? 로그인</a>
    </div>

    <%= f.submit "1분 만에 시작하기",
          class: "w-full rounded-md bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 cursor-pointer" %>
  <% end %>
</section>