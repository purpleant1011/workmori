<% content_for(:title, "Hermes Audit 로그 — Sohee Project 플랫폼") %>
<header class="mb-6">
  <h1 class="text-2xl font-bold text-slate-900">Hermes Audit 로그</h1>
  <p class="mt-1 text-sm text-slate-500"><code>automation.hermes.*</code> / <code>automation.execute.*</code> 액션의 감사 이벤트</p>
</header>
<div class="overflow-x-auto rounded-md border border-slate-200 bg-white">
  <table class="min-w-full divide-y divide-slate-200 text-sm">
    <thead class="bg-slate-50 text-left text-xs font-medium uppercase tracking-wider text-slate-500">
      <tr>
        <th class="px-3 py-2">시각</th>
        <th class="px-3 py-2">액션</th>
        <th class="px-3 py-2">리소스</th>
        <th class="px-3 py-2">메타데이터</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-200">
      <% @events.each do |ev| %>
        <tr>
          <td class="px-3 py-2 text-slate-700 whitespace-nowrap"><%= ev.created_at.strftime("%Y-%m-%d %H:%M:%S") %></td>
          <td class="px-3 py-2 font-mono text-xs"><%= ev.action %></td>
          <td class="px-3 py-2"><%= "#{ev.resource_type}##{ev.resource_id}" %></td>
          <td class="px-3 py-2 max-w-xl truncate font-mono text-xs"><%= ev.metadata.to_json.truncate(200) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
<div class="mt-4">
  <%= link_to "← Hermes 연동", platform_hermes_path, class: "text-sm text-indigo-600 hover:underline" %>
</div>