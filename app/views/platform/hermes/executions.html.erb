<% content_for(:title, "자동화 실행 로그 — WorkMori 플랫폼") %>
<header class="mb-6">
  <h1 class="text-2xl font-bold text-slate-900">자동화 실행 로그</h1>
  <p class="mt-1 text-sm text-slate-500">최근 100건의 자동화 실행 결과입니다.</p>
</header>
<div class="overflow-x-auto rounded-md border border-slate-200 bg-white">
  <table class="min-w-full divide-y divide-slate-200 text-sm">
    <thead class="bg-slate-50 text-left text-xs font-medium uppercase tracking-wider text-slate-500">
      <tr>
        <th class="px-3 py-2">실행 시각</th>
        <th class="px-3 py-2">규칙 ID</th>
        <th class="px-3 py-2">상태</th>
        <th class="px-3 py-2">시도 횟수</th>
        <th class="px-3 py-2">시작</th>
        <th class="px-3 py-2">종료</th>
        <th class="px-3 py-2">메타데이터</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-200">
      <% @executions.each do |ex| %>
        <tr>
          <td class="px-3 py-2 text-slate-700"><%= ex.created_at.strftime("%Y-%m-%d %H:%M:%S") %></td>
          <td class="px-3 py-2"><%= ex.automation_rule_id %></td>
          <td class="px-3 py-2"><%= ex.state %></td>
          <td class="px-3 py-2"><%= ex.respond_to?(:attempts) ? ex.attempts : "-" %></td>
          <td class="px-3 py-2"><%= ex.started_at&.strftime("%H:%M:%S") || "-" %></td>
          <td class="px-3 py-2"><%= ex.finished_at&.strftime("%H:%M:%S") || "-" %></td>
          <td class="px-3 py-2 max-w-md truncate font-mono text-xs"><%= ex.output_json.to_s.truncate(120) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
<div class="mt-4">
  <%= link_to "← Hermes 연동", platform_hermes_path, class: "text-sm text-indigo-600 hover:underline" %>
</div>