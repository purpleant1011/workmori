<h1 class="text-2xl font-bold mb-4">운영자 대시보드</h1>
<div class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-6">
  <% %w[accounts staff industries inquiries open_inquiries contracts_active].each do |k| %>
    <div class="bg-slate-800 rounded p-4">
      <div class="text-sm text-slate-400"><%= k.humanize %></div>
      <div class="text-3xl font-bold"><%= @counts[k.to_sym] %></div>
    </div>
  <% end %>
</div>
<section>
  <h2 class="text-lg font-semibold mb-2">최근 문의</h2>
  <table class="w-full text-sm">
    <thead><tr class="text-left text-slate-400"><th>ID</th><th>종류</th><th>제목</th><th>처리상태</th><th>작성일</th></tr></thead>
    <tbody>
      <% @recent_inquiries.each do |i| %>
        <tr class="border-t border-slate-700"><td><%= i.id %></td><td><%= i.subject_kind %></td><td><%= i.subject %></td><td><%= i.status %></td><td><%= i.created_at&.strftime("%Y-%m-%d %H:%M") %></td></tr>
      <% end %>
    </tbody>
  </table>
</section>
<section class="mt-6">
  <h2 class="text-lg font-semibold mb-2">최근 가입</h2>
  <table class="w-full text-sm">
    <thead><tr class="text-left text-slate-400"><th>ID</th><th>이름</th><th>상태</th><th>가입일</th></tr></thead>
    <tbody>
      <% @recent_signups.each do |a| %>
        <tr class="border-t border-slate-700"><td><%= a.id %></td><td><%= a.name %></td><td><%= a.status %></td><td><%= a.created_at&.strftime("%Y-%m-%d") %></td></tr>
      <% end %>
    </tbody>
  </table>
</section>
