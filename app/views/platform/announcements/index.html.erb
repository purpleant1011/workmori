<% content_for(:title, "공지사항 — WorkMori 플랫폼") %>
<header class="mb-6">
  <h1 class="text-2xl font-bold text-slate-900">공지사항 관리</h1>
  <p class="mt-1 text-sm text-slate-500">전체/특정 사업자에게 공지를 게시합니다. 게시 시 사업자에게 실시간 알림이 전송됩니다.</p>
</header>

<div class="mb-4 flex gap-2">
  <%= link_to "+ 새 공지", new_platform_announcement_path, class: "inline-flex items-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700" %>
</div>

<div class="overflow-x-auto rounded-md border border-slate-200 bg-white">
  <table class="min-w-full divide-y divide-slate-200 text-sm">
    <thead class="bg-slate-50 text-left text-xs font-medium uppercase tracking-wider text-slate-500">
      <tr>
        <th class="px-3 py-2">제목</th>
        <th class="px-3 py-2">종류</th>
        <th class="px-3 py-2">대상</th>
        <th class="px-3 py-2">계정</th>
        <th class="px-3 py-2">상태</th>
        <th class="px-3 py-2">게시일</th>
        <th class="px-3 py-2">액션</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-200">
      <% @announcements.each do |a| %>
        <tr>
          <td class="px-3 py-2"><%= link_to a.title, platform_announcement_path(a), class: "text-indigo-600 hover:underline" %></td>
          <td class="px-3 py-2"><span class="rounded bg-<%= a.kind_color %>-100 px-2 py-0.5 text-xs text-<%= a.kind_color %>-700"><%= a.kind_label %></span></td>
          <td class="px-3 py-2"><%= a.audience %></td>
          <td class="px-3 py-2"><%= a.account&.name || "(전역)" %></td>
          <td class="px-3 py-2"><%= a.status %></td>
          <td class="px-3 py-2 text-xs text-slate-500"><%= a.published_at&.strftime("%Y-%m-%d %H:%M") || "-" %></td>
          <td class="px-3 py-2">
            <% if a.status == "draft" %>
              <%= button_to "게시", publish_platform_announcement_path(a), method: :post, class: "text-xs text-emerald-700 hover:underline" %>
            <% elsif a.status == "published" %>
              <%= button_to "보관", archive_platform_announcement_path(a), method: :post, class: "text-xs text-slate-600 hover:underline" %>
            <% end %>
            <%= link_to "수정", edit_platform_announcement_path(a), class: "text-xs text-indigo-600 hover:underline ml-2" %>
            <%= button_to "삭제", platform_announcement_path(a), method: :delete, data: { turbo_confirm: "정말 삭제하시겠습니까?" }, class: "text-xs text-rose-600 hover:underline ml-2" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>