<% content_for(:title, "공지 수정 — Sohee Project 플랫폼") %>
<header class="mb-6">
  <h1 class="text-2xl font-bold text-slate-900">공지 수정</h1>
</header>

<%= form_with model: @announcement, url: platform_announcement_path(@announcement), method: :patch, local: true, class: "space-y-4 max-w-3xl" do |f| %>
  <% if @announcement.errors.any? %>
    <div class="rounded-md border border-rose-300 bg-rose-50 p-3 text-sm text-rose-700">
      <%= @announcement.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div>
    <%= f.label :title, "제목", class: "block text-sm font-medium text-slate-700" %>
    <%= f.text_field :title, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
  </div>

  <div class="grid grid-cols-3 gap-3">
    <div>
      <%= f.label :kind, "종류", class: "block text-sm font-medium text-slate-700" %>
      <%= f.select :kind, Announcement::KINDS.map { |k| [Announcement.new(kind: k).kind_label, k] }, {}, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :audience, "대상", class: "block text-sm font-medium text-slate-700" %>
      <%= f.select :audience, Announcement::AUDIENCES, {}, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :account_id, "특정 계정", class: "block text-sm font-medium text-slate-700" %>
      <%= f.select :account_id, Account.order(:name).pluck(:name, :id), { include_blank: "(전역)" }, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
  </div>

  <div>
    <%= f.label :body, "본문", class: "block text-sm font-medium text-slate-700" %>
    <%= f.text_area :body, rows: 12, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm font-mono" %>
  </div>

  <div class="flex gap-2">
    <%= f.submit "저장", class: "inline-flex items-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700" %>
    <%= link_to "취소", platform_announcement_path(@announcement), class: "inline-flex items-center rounded-md border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50" %>
  </div>
<% end %>