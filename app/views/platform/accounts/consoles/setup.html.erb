<% content_for :title, "#{@account.name} · 운영 콘솔 — 소희 프로젝트" %>

<%
  pending_count = @pending_actions.size
  incident_count = @recent_incidents.size
  unresolved_count = pending_count + incident_count

  @current_account = @account
  @pending_actions_count = pending_count
%>

<%# ── 헤더 (emerald: 로그인/오늘 박스) ── %>
<section class="rounded-xl border border-emerald-200 bg-emerald-50/60 p-4 mb-4">
  <div class="flex items-center gap-2 text-emerald-900 text-sm">
    <span>✅</span><span>로그인되셨습니다.</span>
  </div>
</section>

<%# ── 셋업 준비도 (큰 박스, amber) ── %>
<% sr = @setup_readiness || { percent: 0, passed: 0, total: 0, ready: false, missing: [] } %>
<% if @setup_counts %>
  <%
    passed = 0; total = 7
    checks = [
      ["매장 소개글과 운영 규칙이 등록되어 있나요", @setup_counts[:knowledge_documents].to_i + @setup_counts[:faqs].to_i > 0 || @setup_status[:knowledge]],
      ["답변 채널 1개 이상이 연결되어 있나요", @setup_status[:channels]],
      ["자주 받는 질문(FAQ)이 등록되어 있나요 (현재 #{@setup_counts[:faqs].to_i}개)", @setup_counts[:faqs].to_i > 0],
      ["검수를 통과한 글이 5건 이상 모였나요", @setup_counts[:content_items].to_i >= 5],
      ["원장님께 인계해야 할 상황 기준이 정해져 있나요", @setup_counts[:business_profiles].to_i > 0],
      ["AI 직원 말투와 역할이 설정되어 있나요", @setup_status[:persona]],
      ["매장 안내 자료가 충분히 등록되어 있나요 (현재 #{@setup_counts[:knowledge_documents].to_i + @setup_counts[:faqs].to_i}건)", @setup_counts[:knowledge_documents].to_i > 0]
    ]
    passed = checks.count { |_, ok| ok }
    pct = (passed * 100 / total)
  %>
  <section class="rounded-xl border-2 border-amber-200 bg-amber-50/60 p-5 mb-4">
    <div class="flex items-start justify-between gap-4 mb-3">
      <div>
        <h2 class="text-base font-bold text-slate-900 flex items-center gap-2">
          <span>🛠️</span> 셋업 준비도
        </h2>
        <p class="text-sm text-slate-600 mt-1">
          운영팀과 함께 정한 항목이 모두 채워지면, 정식 운영으로 전환할 수 있습니다.
        </p>
      </div>
      <div class="text-right">
        <div class="text-3xl font-bold text-amber-700"><%= pct %>%</div>
        <div class="text-xs text-slate-500"><%= passed %>/<%= total %> 항목 통과</div>
      </div>
    </div>

    <div class="h-2 bg-amber-100 rounded-full overflow-hidden mb-4">
      <div class="h-full bg-amber-500 rounded-full transition-all" style="width: <%= pct %>%"></div>
    </div>

    <ul class="space-y-1.5">
      <% checks.each do |label, ok| %>
        <li class="flex items-start gap-2 text-sm <%= ok ? 'text-emerald-700' : 'text-rose-700' %>">
          <span><%= ok ? '✓' : '✕' %></span>
          <span><%= label %></span>
        </li>
      <% end %>
    </ul>

    <p class="text-sm text-slate-700 mt-4 pt-3 border-t border-amber-200">
      다음 단계: 위 <strong>×</strong> 항목을 운영팀과 함께 정리하면 정식 운영으로 전환할 수 있습니다.
    </p>
  </section>
<% end %>

<%# ── 오늘 (emerald, hero + Discord/확인 버튼) ── %>
<section class="rounded-xl border-2 border-emerald-200 bg-emerald-50/60 p-5 mb-4">
  <div class="flex items-start justify-between gap-4">
    <div>
      <h2 class="text-xl font-bold text-slate-900">오늘</h2>
      <p class="text-sm text-slate-600 mt-1">
        <%= @account.name %> · <%= Time.current.strftime("%Y년 %m월 %d일 %A") %>
      </p>
      <% if unresolved_count > 0 %>
        <p class="text-sm text-rose-700 mt-2">
          ⚠️ <strong>확인이 필요한 일 <%= unresolved_count %>건</strong>이 있습니다.
        </p>
      <% else %>
        <p class="text-sm text-emerald-700 mt-2">
          ✅ 확인이 필요한 일 0건 — 모든 항목이 정상입니다.
        </p>
      <% end %>
    </div>
    <div class="flex flex-col gap-2">
      <a href="https://discord.com/channels/@me" class="px-4 py-2 rounded-lg bg-emerald-600 text-white text-sm font-semibold hover:bg-emerald-700 whitespace-nowrap">
        💬 Discord에서 소희와 대화하기
      </a>
      <% if unresolved_count > 0 %>
        <a href="<%= platform_account_console_audit_path(@account) %>" class="px-4 py-2 rounded-lg bg-amber-100 text-amber-900 text-sm font-semibold hover:bg-amber-200 whitespace-nowrap text-center">
          확인할 일 <%= unresolved_count %>건 →
        </a>
      <% end %>
    </div>
  </div>
</section>

<%# ── 4-통계 (오늘완료 / 개시예정 / 처리문의 / 확인필요) ── %>
<section class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-4">
  <div class="rounded-xl border border-slate-200 bg-white p-4">
    <div class="text-3xl font-bold text-emerald-700">0</div>
    <div class="text-sm text-slate-700 mt-1 font-medium">오늘 완료한 일</div>
    <div class="text-xs text-slate-400 mt-0.5">발행 완료 0건</div>
  </div>

  <div class="rounded-xl border border-slate-200 bg-white p-4">
    <div class="text-3xl font-bold text-sky-700">0</div>
    <div class="text-sm text-slate-700 mt-1 font-medium">개시 예정</div>
    <div class="text-xs text-slate-400 mt-0.5">오늘 작성 5건</div>
  </div>

  <div class="rounded-xl border border-slate-200 bg-white p-4">
    <div class="text-3xl font-bold text-indigo-700">0</div>
    <div class="text-sm text-slate-700 mt-1 font-medium">처리한 문의</div>
    <div class="text-xs text-slate-400 mt-0.5">단순 응답 0건</div>
  </div>

  <%= link_to platform_account_console_monitoring_path(@account),
        class: "rounded-xl border-2 border-rose-300 bg-rose-50 p-4 hover:bg-rose-100 transition-colors" do %>
    <div class="flex items-baseline justify-between">
      <div class="text-3xl font-bold text-rose-700"><%= unresolved_count %></div>
      <div class="text-rose-400">→</div>
    </div>
    <div class="text-sm text-rose-800 mt-1 font-medium">확인 필요</div>
    <div class="text-xs text-rose-600 mt-0.5">확인하러 가기</div>
  <% end %>
</section>

<%# ── 셋업 준비도 (큰 박스, 두 번째 등장) ── %>
<% if @setup_status %>
  <section class="rounded-xl border-2 border-amber-300 bg-amber-50/70 p-5 mb-4">
    <div class="flex items-start justify-between gap-4 mb-3">
      <div>
        <h2 class="text-base font-bold text-slate-900 flex items-center gap-2">
          <span>🛠️</span> 셋업 준비도
        </h2>
        <p class="text-sm text-slate-600 mt-1">
          운영팀과 함께 정한 항목이 모두 채워지면, 정식 운영으로 전환할 수 있습니다.
        </p>
      </div>
      <div class="text-right">
        <div class="text-3xl font-bold text-amber-700"><%= pct %>%</div>
        <div class="text-xs text-slate-500"><%= passed %>/<%= total %> 항목 통과</div>
      </div>
    </div>
    <div class="h-2 bg-amber-100 rounded-full overflow-hidden mb-4">
      <div class="h-full bg-amber-500 rounded-full transition-all" style="width: <%= pct %>%"></div>
    </div>
    <ul class="space-y-1.5">
      <% checks.each do |label, ok| %>
        <li class="flex items-start gap-2 text-sm <%= ok ? 'text-emerald-700' : 'text-rose-700' %>">
          <span><%= ok ? '✓' : '✕' %></span>
          <span><%= label %></span>
        </li>
      <% end %>
    </ul>
    <p class="text-sm text-slate-700 mt-4 pt-3 border-t border-amber-200">
      다음 단계: 위 <strong>×</strong> 항목을 운영팀과 함께 정리하면 정식 운영으로 전환할 수 있습니다.
    </p>
  </section>
<% end %>

<%# ── 확인이 필요한 항목 (amber 박스) ── %>
<section class="rounded-xl border-2 border-amber-200 bg-amber-50/60 p-5 mb-4">
  <div class="flex items-baseline justify-between mb-3">
    <h2 class="text-base font-bold text-slate-900 flex items-center gap-2">
      <span>⚠️</span> 확인이 필요한 항목 (<%= unresolved_count %>건)
    </h2>
    <%= link_to "모두 보기 →", platform_account_console_audit_path(@account),
          class: "text-xs text-slate-600 hover:text-slate-900" %>
  </div>

  <% if @pending_actions.any? %>
    <h3 class="text-xs font-semibold text-amber-800 uppercase mt-2 mb-2">⚠️ 원장님 답변이 필요한 문의 (<%= @pending_actions.size %>건)</h3>
    <ul class="space-y-2 mb-4">
      <% @pending_actions.first(3).each do |p| %>
        <li class="rounded-lg border border-rose-200 bg-white p-3 flex items-start justify-between gap-3">
          <div>
            <span class="inline-block text-xs px-2 py-0.5 rounded bg-rose-100 text-rose-700 font-medium mr-2">가게 조정 요청</span>
            <span class="text-sm text-slate-800"><%= p.title.presence || "제안 ##{p.id}" %></span>
            <p class="text-xs text-slate-500 mt-1"><%= p.created_at&.strftime("%Y-%m-%d %H:%M") %></p>
          </div>
          <span class="text-xs text-slate-600 hover:text-slate-900 whitespace-nowrap">확인</span>
        </li>
      <% end %>
    </ul>
  <% end %>

  <% if @recent_incidents.any? %>
    <h3 class="text-xs font-semibold text-amber-800 uppercase mt-2 mb-2">⚠️ 인시던트 (<%= @recent_incidents.size %>건)</h3>
    <ul class="space-y-2">
      <% @recent_incidents.first(3).each do |i| %>
        <li class="rounded-lg border border-rose-200 bg-white p-3 flex items-start justify-between gap-3">
          <div>
            <span class="inline-block text-xs px-2 py-0.5 rounded bg-rose-100 text-rose-700 font-medium mr-2">전환 판단 요청</span>
            <span class="text-sm text-slate-800"><%= i.title.presence || "인시던트 ##{i.id}" %></span>
            <p class="text-xs text-slate-500 mt-1"><%= i.status %> · <%= i.severity %></p>
          </div>
          <%= link_to "확인", platform_account_console_monitoring_path(@account),
                class: "text-xs text-slate-600 hover:text-slate-900 whitespace-nowrap" %>
        </li>
      <% end %>
    </ul>
  <% end %>

  <% if @pending_actions.empty? && @recent_incidents.empty? %>
    <div class="rounded-lg border border-emerald-200 bg-emerald-50 p-4 text-center text-sm text-emerald-700">
      ✅ 현재 확인이 필요한 항목이 없습니다.
    </div>
  <% end %>
</section>

<%# ── 통제 액션 (별도 박스) ── %>
<section class="rounded-xl border border-slate-200 bg-white p-4 mb-4">
  <h3 class="text-xs font-semibold text-slate-500 uppercase mb-3">통제 액션</h3>
  <div class="flex flex-wrap gap-2">
    <% if @account.status == "suspended" %>
      <%= button_to "재개", reactivate_platform_account_path(@account), method: :post,
            class: "px-3 py-2 rounded-lg bg-emerald-600 text-white text-sm font-medium hover:bg-emerald-700" %>
    <% else %>
      <%= button_to "긴급 일시중지", suspend_platform_account_path(@account), method: :post,
            class: "px-3 py-2 rounded-lg bg-rose-600 text-white text-sm font-medium hover:bg-rose-700",
            data: { confirm: "이 사업자의 모든 자동 실행을 일시중지합니다. 계속할까요?" } %>
    <% end %>
    <%= button_to "Discord 강제 동기화", discord_resync_platform_account_path(@account), method: :post,
          class: "px-3 py-2 rounded-lg bg-slate-700 text-white text-sm font-medium hover:bg-slate-600" %>
  </div>
</section>